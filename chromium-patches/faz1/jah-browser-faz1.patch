+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_JAH_MULTI_JAH_MULTI_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_JAH_MULTI_JAH_MULTI_UI_H_
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+
+class JahMultiUI;
+
+// WebUIConfig for the JahBrowser "Coklu Yayin" multistream grid page
+// (chrome://jah-multi). Registered in
+// chrome/browser/ui/webui/chrome_web_ui_configs.cc.
+class JahMultiUIConfig : public content::DefaultWebUIConfig<JahMultiUI> {
+ public:
+  JahMultiUIConfig();
+};
+
+// WebUIController that serves the static JahBrowser multistream page. The page
+// is fully self-contained (tokens + styles + script inlined) and is served
+// directly from a request filter, so no grit/build_webui pipeline is required.
+// A JahMultiMessageHandler feeds the initial channel list (hero + Kick follows)
+// via the chrome.send bridge (jahMultiGetChannels -> jahOnChannels).
+class JahMultiUI : public content::WebUIController {
+ public:
+  explicit JahMultiUI(content::WebUI* web_ui);
+  JahMultiUI(const JahMultiUI&) = delete;
+  JahMultiUI& operator=(const JahMultiUI&) = delete;
+  ~JahMultiUI() override;
+};
