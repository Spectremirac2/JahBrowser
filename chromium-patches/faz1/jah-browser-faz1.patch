+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_JAH_ONBOARDING_JAH_ONBOARDING_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_JAH_ONBOARDING_JAH_ONBOARDING_UI_H_
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+
+class JahOnboardingUI;
+
+// WebUIConfig for the JahBrowser first-run / "Sade Mod" onboarding page
+// (chrome://jah-onboarding). Registered in
+// chrome/browser/ui/webui/chrome_web_ui_configs.cc.
+class JahOnboardingUIConfig
+    : public content::DefaultWebUIConfig<JahOnboardingUI> {
+ public:
+  JahOnboardingUIConfig();
+};
+
+// WebUIController that serves the static JahBrowser onboarding page. The page
+// is fully self-contained (tokens + styles + script inlined) and is served
+// directly from a request filter, so no grit/build_webui pipeline is required.
+// It surfaces the existing Chromium import UI (chrome://settings/importData)
+// with zero new Mojo.
+class JahOnboardingUI : public content::WebUIController {
+ public:
+  explicit JahOnboardingUI(content::WebUI* web_ui);
+  JahOnboardingUI(const JahOnboardingUI&) = delete;
+  JahOnboardingUI& operator=(const JahOnboardingUI&) = delete;
+  ~JahOnboardingUI() override;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_JAH_ONBOARDING_JAH_ONBOARDING_UI_H_
diff --git a/chrome/browser/ui/webui/jah_onboarding/resources/jah_onboarding_page.inc b/chrome/browser/ui/webui/jah_onboarding/resources/jah_onboarding_page.inc
new file mode 100644
index 0000000000..e6dbd8e7d5
--- /dev/null
+++ b/chrome/browser/ui/webui/jah_onboarding/resources/jah_onboarding_page.inc
@@ -0,0 +1,366 @@
+R"JAHONB(<!DOCTYPE html>
+<html lang="tr">
+<head>
+<meta charset="UTF-8">
+<meta name="viewport" content="width=device-width, initial-scale=1.0">
+<title>JahBrowser'a Hoş Geldin</title>
+<style>
+  /* ============================================================
+     JahBrowser — Jah Temasi tokenlari (jah-theme.css'ten satir ici)
+     ============================================================ */
+  :root {
+    color-scheme: dark;
+
+    --jah-bg: #0B0E0F;
+    --jah-surface: #191B1F;
+    --jah-surface-2: #24272C;
+    --jah-surface-overlay: #2C3036;
+    --jah-border: #33383F;
+    --jah-border-strong: #474F54;
+
+    --jah-text: #F2F2F0;
+    --jah-text-dim: #9BA1A6;
+    --jah-text-muted: #6B7178;
+    --jah-text-on-accent: #0B0E0F;
+
+    --jah-accent: #53FC18;
+    --jah-accent-hover: #71FD44;
+    --jah-accent-pressed: #3FD30E;
+    --jah-accent-subtle: rgba(83, 252, 24, 0.12);
+    --jah-accent-glow: 0 0 12px rgba(83, 252, 24, 0.45);
+    --jah-gold: #C9A227;
+    --jah-gold-subtle: rgba(201, 162, 39, 0.14);
+
+    --jah-font-ui: "Segoe UI", system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
+
+    --jah-space-1: 4px;
+    --jah-space-2: 8px;
+    --jah-space-3: 12px;
+    --jah-space-4: 16px;
+    --jah-space-6: 24px;
+    --jah-space-8: 32px;
+
+    --jah-radius-md: 8px;
+    --jah-radius-lg: 12px;
+    --jah-radius-full: 999px;
+
+    --jah-shadow-lg: 0 8px 28px rgba(0, 0, 0, 0.6);
+
+    --jah-ease: cubic-bezier(0.2, 0, 0, 1);
+  }
+
+  * { margin: 0; padding: 0; box-sizing: border-box; }
+  html, body { height: 100%; }
+
+  body {
+    background: var(--jah-bg);
+    color: var(--jah-text);
+    font-family: var(--jah-font-ui);
+    font-size: 14px;
+    line-height: 20px;
+    overflow-x: hidden;
+    -webkit-font-smoothing: antialiased;
+  }
+
+  .atmosphere {
+    position: fixed;
+    inset: 0;
+    z-index: 0;
+    pointer-events: none;
+    background:
+      radial-gradient(1100px 520px at 50% -12%, var(--jah-accent-subtle), transparent 68%),
+      radial-gradient(900px 700px at 88% 112%, var(--jah-gold-subtle), transparent 62%),
+      var(--jah-bg);
+  }
+
+  .page {
+    position: relative;
+    z-index: 1;
+    min-height: 100vh;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    padding: var(--jah-space-8) var(--jah-space-6);
+  }
+
+  .card {
+    width: 100%;
+    max-width: 560px;
+    background: var(--jah-surface);
+    border: 1px solid var(--jah-border);
+    border-radius: var(--jah-radius-lg);
+    box-shadow: var(--jah-shadow-lg);
+    padding: var(--jah-space-8);
+  }
+
+  @keyframes jah-rise {
+    from { opacity: 0; transform: translateY(14px); }
+    to   { opacity: 1; transform: translateY(0); }
+  }
+  .rise { opacity: 0; animation: jah-rise 560ms var(--jah-ease) forwards; }
+  .rise-1 { animation-delay: 40ms; }
+  .rise-2 { animation-delay: 140ms; }
+  .rise-3 { animation-delay: 240ms; }
+  .rise-4 { animation-delay: 340ms; }
+
+  @media (prefers-reduced-motion: reduce) {
+    .rise { animation: none; opacity: 1; }
+    * { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
+  }
+
+  .brand {
+    display: inline-flex;
+    align-items: center;
+    gap: var(--jah-space-2);
+    font-size: 12px;
+    font-weight: 700;
+    text-transform: uppercase;
+    letter-spacing: 0.1em;
+    color: var(--jah-text-muted);
+    margin-bottom: var(--jah-space-4);
+  }
+  .brand .dot {
+    width: 8px; height: 8px;
+    border-radius: var(--jah-radius-full);
+    background: var(--jah-accent);
+    box-shadow: var(--jah-accent-glow);
+  }
+
+  h1 {
+    font-size: 28px;
+    line-height: 34px;
+    font-weight: 700;
+    letter-spacing: -0.02em;
+    margin-bottom: var(--jah-space-3);
+  }
