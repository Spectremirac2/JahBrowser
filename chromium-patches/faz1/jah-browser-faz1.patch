+R"JAHSET(<!DOCTYPE html>
+<html lang="tr">
+<head>
+<meta charset="UTF-8">
+<meta name="viewport" content="width=device-width, initial-scale=1.0">
+<title>JahBrowser Kontrol Merkezi</title>
+<style>
+  /* ============================================================
+     JahBrowser — Jah Temasi tokenlari (jah-onboarding ile ayni)
+     ============================================================ */
+  :root {
+    color-scheme: dark;
+
+    --jah-bg: #0A0E13;
+    --jah-surface: #141C28;
+    --jah-surface-2: #1C2735;
+    --jah-surface-overlay: #24303E;
+    --jah-border: #232E3B;
+    --jah-border-strong: #33414F;
+
+    --jah-text: #E4E8ED;
+    --jah-text-dim: #8A94A0;
+    --jah-text-muted: #59636F;
+    --jah-text-on-accent: #0B0E0F;
+
+    --jah-accent: #53FC18;
+    --jah-accent-hover: #71FD44;
+    --jah-accent-pressed: #3FD30E;
+    --jah-accent-subtle: rgba(83, 252, 24, 0.12);
+    --jah-accent-glow: 0 0 12px rgba(83, 252, 24, 0.45);
+    --jah-gold: #C9A227;
+    --jah-gold-subtle: rgba(201, 162, 39, 0.14);
+
+    --jah-font-ui: "Segoe UI", system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
+    --jah-font-mono: "Cascadia Code", "Consolas", ui-monospace, monospace;
+
+    --jah-space-1: 4px;
+    --jah-space-2: 8px;
+    --jah-space-3: 12px;
+    --jah-space-4: 16px;
+    --jah-space-6: 24px;
+    --jah-space-8: 32px;
+
+    --jah-radius-md: 8px;
+    --jah-radius-lg: 12px;
+    --jah-radius-full: 999px;
+
+    --jah-shadow-lg: 0 8px 28px rgba(0, 0, 0, 0.6);
+
+    --jah-ease: cubic-bezier(0.2, 0, 0, 1);
+  }
+
+  * { margin: 0; padding: 0; box-sizing: border-box; }
+  html, body { height: 100%; }
+
+  body {
+    background: var(--jah-bg);
+    color: var(--jah-text);
+    font-family: var(--jah-font-ui);
+    font-size: 14px;
+    line-height: 20px;
+    overflow-x: hidden;
+    -webkit-font-smoothing: antialiased;
+  }
+
+  .atmosphere {
+    position: fixed;
+    inset: 0;
+    z-index: 0;
+    pointer-events: none;
+    background:
+      radial-gradient(1100px 520px at 50% -12%, var(--jah-accent-subtle), transparent 68%),
+      radial-gradient(900px 700px at 88% 112%, var(--jah-gold-subtle), transparent 62%),
+      var(--jah-bg);
+  }
+
+  .page {
+    position: relative;
+    z-index: 1;
+    min-height: 100vh;
+    display: flex;
+    justify-content: center;
+    padding: var(--jah-space-8) var(--jah-space-6);
+  }
+
+  .wrap { width: 100%; max-width: 720px; }
+
+  .brand {
+    display: inline-flex;
+    align-items: center;
+    gap: var(--jah-space-2);
+    font-size: 12px;
+    font-weight: 700;
+    text-transform: uppercase;
+    letter-spacing: 0.1em;
+    color: var(--jah-text-muted);
+    margin-bottom: var(--jah-space-3);
+  }
+  .brand .dot {
+    width: 8px; height: 8px;
+    border-radius: var(--jah-radius-full);
+    background: var(--jah-accent);
+    box-shadow: var(--jah-accent-glow);
+  }
+
+  h1 {
+    font-size: 26px;
+    line-height: 32px;
+    font-weight: 700;
+    letter-spacing: -0.02em;
+    margin-bottom: var(--jah-space-2);
+  }
+  h1 strong { color: var(--jah-accent); font-weight: 700; }
+
+  .lede {
+    font-size: 15px;
+    line-height: 22px;
+    color: var(--jah-text-dim);
+    margin-bottom: var(--jah-space-8);
+  }
+
+  .section {
+    background: var(--jah-surface);
+    border: 1px solid var(--jah-border);
+    border-radius: var(--jah-radius-lg);
+    box-shadow: var(--jah-shadow-lg);
+    padding: var(--jah-space-6);
+    margin-bottom: var(--jah-space-6);
+  }
+  .section h2 {
+    font-size: 12px;
+    font-weight: 700;
+    text-transform: uppercase;
+    letter-spacing: 0.08em;
+    color: var(--jah-text-muted);
+    margin-bottom: var(--jah-space-4);
+  }
+
+  /* --- Toggle rows --- */
+  .row {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: var(--jah-space-4);
+    padding: var(--jah-space-3) 0;
+    border-top: 1px solid var(--jah-border);
+  }
+  .row:first-of-type { border-top: none; }
+  .row .txt b { font-weight: 600; display: block; }
+  .row .txt span { color: var(--jah-text-muted); font-size: 13px; }
+
+  .switch {
+    flex: none;
+    position: relative;
+    width: 46px; height: 26px;
+    border-radius: var(--jah-radius-full);
+    background: var(--jah-surface-overlay);
+    border: 1px solid var(--jah-border-strong);
+    cursor: pointer;
+    transition: background 140ms var(--jah-ease), border-color 140ms var(--jah-ease);
+  }
+  .switch::after {
+    content: "";
+    position: absolute;
+    top: 2px; left: 2px;
+    width: 20px; height: 20px;
+    border-radius: var(--jah-radius-full);
+    background: var(--jah-text-dim);
+    transition: transform 140ms var(--jah-ease), background 140ms var(--jah-ease);
+  }
+  .switch[aria-checked="true"] {
+    background: var(--jah-accent);
+    border-color: transparent;
+    box-shadow: var(--jah-accent-glow);
+  }
+  .switch[aria-checked="true"]::after {
+    transform: translateX(20px);
+    background: var(--jah-text-on-accent);
+  }
+  .switch:focus-visible {
+    outline: 2px solid var(--jah-accent);
+    outline-offset: 2px;
+  }
+
+  /* --- Balta counter --- */
+  .balta {
+    display: flex;
+    align-items: baseline;
+    gap: var(--jah-space-3);
+  }
+  .balta .num {
+    font-size: 40px;
+    line-height: 1;
+    font-weight: 700;
+    color: var(--jah-accent);
+    font-variant-numeric: tabular-nums;
+  }
+  .balta .cap { color: var(--jah-text-dim); font-size: 14px; }
+
+  /* --- DNS segmented control --- */
+  .seg {
+    display: flex;
+    flex-wrap: wrap;
+    gap: var(--jah-space-2);
+  }
+  .seg button {
+    flex: 1 1 auto;
+    min-width: 92px;
+    background: var(--jah-surface-2);
+    color: var(--jah-text-dim);
+    border: 1px solid var(--jah-border);
+    font-family: var(--jah-font-ui);
+    font-size: 14px;
+    font-weight: 600;
+    padding: var(--jah-space-3) var(--jah-space-4);
+    border-radius: var(--jah-radius-md);
+    cursor: pointer;
+    transition: background 120ms var(--jah-ease),
+                border-color 120ms var(--jah-ease),
+                color 120ms var(--jah-ease);
+  }
+  .seg button:hover {
+    background: var(--jah-surface-overlay);
+    border-color: var(--jah-border-strong);
+    color: var(--jah-text);
+  }
+  .seg button[aria-pressed="true"] {
+    background: var(--jah-accent-subtle);
+    border-color: var(--jah-accent);
+    color: var(--jah-accent);
+  }
+  .seg button:focus-visible {
+    outline: 2px solid var(--jah-accent);
+    outline-offset: 2px;
+  }
+
+  /* --- Search shortcuts table --- */
+  table.shortcuts {
+    width: 100%;
+    border-collapse: collapse;
+    font-size: 14px;
+  }
+  table.shortcuts th, table.shortcuts td {
+    text-align: left;
+    padding: var(--jah-space-2) var(--jah-space-3);
+    border-top: 1px solid var(--jah-border);
+  }
+  table.shortcuts thead th {
+    border-top: none;
+    color: var(--jah-text-muted);
+    font-size: 12px;
+    text-transform: uppercase;
+    letter-spacing: 0.06em;
+  }
