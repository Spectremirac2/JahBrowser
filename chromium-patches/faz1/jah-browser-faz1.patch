+using SidePanelWebUIViewT_JahLiveUI = SidePanelWebUIViewT<JahLiveUI>;
+BEGIN_TEMPLATE_METADATA(SidePanelWebUIViewT_JahLiveUI, SidePanelWebUIViewT)
+END_METADATA
+
+JahLiveSidePanelWebView::JahLiveSidePanelWebView(
+    Profile* profile,
+    SidePanelEntryScope& scope,
+    base::RepeatingClosure close_cb)
+    : SidePanelWebUIViewT(
+          scope,
+          /*on_show_cb=*/base::RepeatingClosure(),
+          close_cb,
+          std::make_unique<WebUIContentsWrapperT<JahLiveUI>>(
+              GURL(chrome::kChromeUIJahLiveSidePanelURL),
+              profile,
+              IDS_JAH_LIVE_TITLE,
+              /*esc_closes_ui=*/false)) {
+  // The Jah live/hub page is a static, browser-rendered WebUI: it never calls
+  // the mojo ShowUI() handshake that bookmarks/reading-list panels use to mark
+  // themselves available. Without this, SidePanelContentProxy::IsAvailable()
+  // stays false forever, SidePanelEntryWaiter never runs PopulateSidePanel, and
+  // the panel view is never opened (stays 0-width). Mark it available up front.
+  SidePanelUtil::GetSidePanelContentProxy(this)->SetAvailable(true);
+  SetVisible(true);
+}
+
+JahLiveSidePanelWebView::~JahLiveSidePanelWebView() = default;
+
+BEGIN_METADATA(JahLiveSidePanelWebView)
+END_METADATA
