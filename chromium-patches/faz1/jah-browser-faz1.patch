+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_JAH_JAH_GOLIVE_SERVICE_H_
+#define CHROME_BROWSER_JAH_JAH_GOLIVE_SERVICE_H_
+
+#include <map>
+#include <memory>
+#include <optional>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "base/memory/scoped_refptr.h"
+#include "base/memory/weak_ptr.h"
+#include "base/timer/timer.h"
+#include "components/keyed_service/core/keyed_service.h"
+
+class Profile;
+
+namespace network {
+class SharedURLLoaderFactory;
+class SimpleURLLoader;
+}  // namespace network
+
+// Browser-process background poller. Every 60s it GETs the public Kick channel
+// endpoint (no cookies, no CORS) for Jahrein plus the curated follow list and,
+// on a per-channel offline->live transition, shows a Windows system toast even
+// when no jah-home tab is open. Owned by the profile via
+// JahGoLiveServiceFactory. Never crashes: on any error it simply keeps the last
+// known state and retries next tick.
+class JahGoLiveService : public KeyedService {
+ public:
+  explicit JahGoLiveService(Profile* profile);
+  ~JahGoLiveService() override;
+
+  JahGoLiveService(const JahGoLiveService&) = delete;
+  JahGoLiveService& operator=(const JahGoLiveService&) = delete;
+
+  // KeyedService:
+  void Shutdown() override;
+
+ private:
+  // Starts (or restarts) a full sweep across all channels.
+  void Poll();
+  // Fetches the channel at |index| in the static channel table.
+  void FetchChannel(size_t index);
+  void OnResponse(size_t index, std::optional<std::string> body);
+  void ShowGoLiveNotification(const std::string& slug,
+                              const std::string& display_name,
+                              const std::string& stream_title);
+  void OpenChannel(const std::string& slug);
+
+  raw_ptr<Profile> profile_;
+  base::RepeatingTimer timer_;
+  std::unique_ptr<network::SimpleURLLoader> loader_;
+  scoped_refptr<network::SharedURLLoaderFactory> factory_;
+  // True while a sweep is in flight; keeps sweeps single-threaded/sequential.
+  bool fetch_in_progress_ = false;
+  // slug -> last known live state. A slug is absent until its first successful
+  // poll establishes a baseline, so we never fire a toast just because the
+  // channel was already live at startup.
+  std::map<std::string, bool> was_live_;
+
+  base::WeakPtrFactory<JahGoLiveService> weak_factory_{this};
+};
+
+#endif  // CHROME_BROWSER_JAH_JAH_GOLIVE_SERVICE_H_
