+<script>
+(function () {
+  "use strict";
+
+  // ---------------- Dil (i18n) ----------------
+  // Turkce varsayilan; yalnizca navigator.language "en*" oldugunda Ingilizce.
+  var JLANG = (navigator.language || "tr").toLowerCase().indexOf("en") === 0 ? "en" : "tr";
+  document.documentElement.lang = JLANG;
+  document.querySelectorAll("[data-i18n-tr]").forEach(function (el) {
+    var v = el.getAttribute(JLANG === "en" ? "data-i18n-en" : "data-i18n-tr");
+    if (v !== null) el.textContent = v;
+  });
+
+  // Butonlar mevcut Chromium ekranlarina yonlendirir; yeni mojo yok.
+  function go(el, url) {
+    var n = document.getElementById(el);
+    if (n) { n.addEventListener("click", function () { window.location.href = url; }); }
+  }
+  go("btnImport", "chrome://settings/importData");
+  go("btnDefault", "chrome://settings/defaultBrowser");
+  go("btnStart", "chrome://jah-home");
+})();
+</script>
+
+</body>
+</html>
+)JAHONB"
