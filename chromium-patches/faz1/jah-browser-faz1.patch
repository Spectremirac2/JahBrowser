new file mode 100644
index 0000000000..ac5d60ec71
--- /dev/null
+++ b/chrome/browser/ui/webui/jah_balta/jah_balta_bubble_message_handler.cc
@@ -0,0 +1,64 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/jah_balta/jah_balta_bubble_message_handler.h"
+
+#include "base/functional/bind.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/ui/webui/jah_balta/jah_balta_bubble_ui.h"
+#include "chrome/common/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/web_ui.h"
+
+JahBaltaBubbleMessageHandler::JahBaltaBubbleMessageHandler() = default;
+JahBaltaBubbleMessageHandler::~JahBaltaBubbleMessageHandler() = default;
+
+void JahBaltaBubbleMessageHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "jahBaltaReady",
+      base::BindRepeating(&JahBaltaBubbleMessageHandler::HandleReady,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahGetBalta",
+      base::BindRepeating(&JahBaltaBubbleMessageHandler::HandleGet,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahToggleBalta",
+      base::BindRepeating(&JahBaltaBubbleMessageHandler::HandleToggle,
+                          base::Unretained(this)));
+}
+
+void JahBaltaBubbleMessageHandler::HandleReady(const base::ListValue& args) {
+  // The bubble widget is created hidden; make it visible now that the page has
+  // loaded (the availability handshake — without it the bubble never appears).
+  auto* controller = static_cast<JahBaltaBubbleUI*>(web_ui()->GetController());
+  if (controller && controller->embedder()) {
+    controller->embedder()->ShowUI();
+  }
+}
+
+void JahBaltaBubbleMessageHandler::HandleGet(const base::ListValue& args) {
+  SendState();
+}
+
+void JahBaltaBubbleMessageHandler::HandleToggle(const base::ListValue& args) {
+  std::optional<bool> on = args.size() > 0 ? args[0].GetIfBool() : std::nullopt;
+  if (g_browser_process && g_browser_process->local_state() &&
+      on.has_value()) {
+    g_browser_process->local_state()->SetBoolean(prefs::kJahBaltaEnabled, *on);
+  }
+  SendState();
+}
+
+void JahBaltaBubbleMessageHandler::SendState() {
+  AllowJavascript();
+  base::DictValue state;
+  PrefService* ls =
+      g_browser_process ? g_browser_process->local_state() : nullptr;
+  state.Set("enabled", ls ? ls->GetBoolean(prefs::kJahBaltaEnabled) : true);
+  state.Set("adsBlocked",
+            ls ? ls->GetInteger(prefs::kJahBaltaAdsBlocked) : 0);
+  web_ui()->CallJavascriptFunctionUnsafe("jahOnBalta",
+                                         base::Value(std::move(state)));
+}
