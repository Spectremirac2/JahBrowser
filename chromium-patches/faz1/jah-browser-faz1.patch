+#include "ui/views/bubble/bubble_border.h"
+#include "url/gurl.h"
+
+namespace {
+// JahBrowser accent (--jah-accent) when on; muted grey (--jah-text-dim) when off.
+constexpr SkColor kJahBaltaOn = SkColorSetRGB(0x53, 0xFC, 0x18);
+constexpr SkColor kJahBaltaOff = SkColorSetRGB(0x6A, 0x70, 0x79);
+constexpr int kJahBaltaIconSize = 18;
+}  // namespace
+
+JahBaltaButton::JahBaltaButton(
+    PrefService* local_state,
+    BrowserWindowInterface* browser_window_interface)
+    : ToolbarButton(base::BindRepeating(&JahBaltaButton::OnPressed,
+                                        base::Unretained(this))),
+      browser_window_interface_(browser_window_interface),
+      bubble_manager_(WebUIBubbleManager::Create<JahBaltaBubbleUI>(
+          browser_window_interface,
+          GURL(chrome::kChromeUIJahBaltaBubbleURL),
+          IDS_JAH_LIVE_TITLE,
+          /*force_load_on_create=*/true)) {
+  balta_enabled_pref_.Init(
+      prefs::kJahBaltaEnabled, local_state,
+      base::BindRepeating(&JahBaltaButton::UpdateState, base::Unretained(this)));
+  ads_blocked_pref_.Init(
+      prefs::kJahBaltaAdsBlocked, local_state,
+      base::BindRepeating(&JahBaltaButton::UpdateState, base::Unretained(this)));
+  UpdateState();
+}
+
+JahBaltaButton::~JahBaltaButton() = default;
+
+void JahBaltaButton::OnPressed() {
+  // uBlock-style: click opens the Balta popup below the button; click again
+  // (or elsewhere) closes it.
+  if (bubble_manager_->GetBubbleWidget()) {
+    bubble_manager_->CloseBubble();
+    return;
+  }
+  bubble_manager_->ShowBubble(this, views::BubbleBorder::TOP_RIGHT);
+}
+
+void JahBaltaButton::UpdateState() {
+  const bool on = balta_enabled_pref_.GetValue();
+  SetImageModel(views::Button::STATE_NORMAL,
+                ui::ImageModel::FromVectorIcon(vector_icons::kAdOffIcon,
+                                               on ? kJahBaltaOn : kJahBaltaOff,
+                                               kJahBaltaIconSize));
+  const std::u16string count =
+      base::FormatNumber(ads_blocked_pref_.GetValue());
+  SetTooltipText(
+      on ? base::StrCat({u"Balta açık — bugün ", count,
+                         u" reklam engellendi"})
+         : u"Balta kapalı — reklamlar engellenmiyor");
+}
+
+BEGIN_METADATA(JahBaltaButton)
+END_METADATA
