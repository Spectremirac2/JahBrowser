diff --git a/chrome/browser/ui/webui/jah_settings/jah_settings_message_handler.cc b/chrome/browser/ui/webui/jah_settings/jah_settings_message_handler.cc
new file mode 100644
index 0000000000..3bbcca5482
--- /dev/null
+++ b/chrome/browser/ui/webui/jah_settings/jah_settings_message_handler.cc
@@ -0,0 +1,251 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/jah_settings/jah_settings_message_handler.h"
+
+#include <optional>
+#include <string>
+#include <string_view>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/pref_names.h"
+#include "components/language/core/browser/pref_names.h"
+#include "components/performance_manager/public/user_tuning/prefs.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/web_ui.h"
+
+namespace {
+
+// DoH mode pref string values (net secure-DNS modes).
+constexpr char kDohModeOff[] = "off";
+constexpr char kDohModeAutomatic[] = "automatic";
+constexpr char kDohModeSecure[] = "secure";
+
+// Well-known DoH resolver templates, keyed by the page's provider id.
+constexpr char kTplCloudflare[] = "https://cloudflare-dns.com/dns-query";
+constexpr char kTplGoogle[] = "https://dns.google/dns-query";
+constexpr char kTplQuad9[] = "https://dns.quad9.net/dns-query";
+constexpr char kTplAdguard[] = "https://dns.adguard-dns.com/dns-query";
+
+// Maps the current local_state DoH prefs to one of the page provider ids:
+// "off" / "auto" / "cloudflare" / "google" / "quad9" / "adguard".
+std::string DeriveDnsProvider(PrefService* local_state) {
+  if (!local_state) {
+    return "auto";
+  }
+  const std::string mode = local_state->GetString(prefs::kDnsOverHttpsMode);
+  if (mode == kDohModeOff) {
+    return "off";
+  }
+  if (mode == kDohModeAutomatic) {
+    return "auto";
+  }
+  // Secure mode: match the configured template to a known provider.
+  const std::string tpl =
+      local_state->GetString(prefs::kDnsOverHttpsTemplates);
+  if (tpl == kTplCloudflare) {
+    return "cloudflare";
+  }
+  if (tpl == kTplGoogle) {
+    return "google";
+  }
+  if (tpl == kTplQuad9) {
+    return "quad9";
+  }
+  if (tpl == kTplAdguard) {
+    return "adguard";
+  }
+  // Secure mode with an unrecognized/custom template: report as automatic.
+  return "auto";
+}
+
+}  // namespace
+
+JahSettingsMessageHandler::JahSettingsMessageHandler() = default;
+JahSettingsMessageHandler::~JahSettingsMessageHandler() = default;
+
+void JahSettingsMessageHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "jahGetSettings",
+      base::BindRepeating(&JahSettingsMessageHandler::HandleGetSettings,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahSetToggle",
+      base::BindRepeating(&JahSettingsMessageHandler::HandleSetToggle,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahSetDns",
+      base::BindRepeating(&JahSettingsMessageHandler::HandleSetDns,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahSetLang",
+      base::BindRepeating(&JahSettingsMessageHandler::HandleSetLang,
+                          base::Unretained(this)));
+}
+
+void JahSettingsMessageHandler::HandleGetSettings(const base::ListValue& args) {
+  SendSettings();
+}
+
+void JahSettingsMessageHandler::HandleSetToggle(const base::ListValue& args) {
+  Profile* profile = Profile::FromWebUI(web_ui());
+  // Args: [name, bool].
+  const std::string* name = args.size() > 0 ? args[0].GetIfString() : nullptr;
+  std::optional<bool> value =
+      args.size() > 1 ? args[1].GetIfBool() : std::nullopt;
+  if (!profile || !name || !value.has_value()) {
+    SendSettings();
+    return;
+  }
+  PrefService* prefs = profile->GetPrefs();
+  if (*name == "broadcastMode") {
+    prefs->SetBoolean(prefs::kJahBroadcastMode, *value);
+  } else if (*name == "forceDark") {
+    prefs->SetBoolean(prefs::kWebKitForceDarkModeEnabled, *value);
+  } else if (*name == "memorySaver") {
+    // Memory Saver lives in local_state as an int enum (0 disabled / 2 on).
+    namespace ptp = performance_manager::user_tuning::prefs;
+    if (g_browser_process && g_browser_process->local_state()) {
+      g_browser_process->local_state()->SetInteger(
+          ptp::kMemorySaverModeState,
+          static_cast<int>(*value ? ptp::MemorySaverModeState::kEnabled
+                                  : ptp::MemorySaverModeState::kDisabled));
+    }
+  } else if (*name == "baltaEnabled") {
+    if (g_browser_process && g_browser_process->local_state()) {
+      g_browser_process->local_state()->SetBoolean(prefs::kJahBaltaEnabled,
+                                                    *value);
+    }
+  } else if (*name == "emotesEnabled") {
+    if (g_browser_process && g_browser_process->local_state()) {
+      g_browser_process->local_state()->SetBoolean(prefs::kJahEmotesEnabled,
+                                                   *value);
+    }
+  } else if (*name == "volumeBooster") {
+    if (g_browser_process && g_browser_process->local_state()) {
+      g_browser_process->local_state()->SetBoolean(
+          prefs::kJahVolumeBoosterEnabled, *value);
+    }
+  }
+  SendSettings();
+}
+
+void JahSettingsMessageHandler::HandleSetDns(const base::ListValue& args) {
+  if (!g_browser_process) {
+    SendSettings();
+    return;
+  }
+  PrefService* local_state = g_browser_process->local_state();
+  const std::string* provider =
+      args.size() > 0 ? args[0].GetIfString() : nullptr;
+  if (!local_state || !provider) {
+    SendSettings();
+    return;
+  }
+
+  std::string mode = kDohModeAutomatic;
+  std::string templates;
+  if (*provider == "off") {
+    mode = kDohModeOff;
+    templates.clear();
+  } else if (*provider == "auto") {
+    mode = kDohModeAutomatic;
+    templates.clear();
+  } else if (*provider == "cloudflare") {
+    mode = kDohModeSecure;
+    templates = kTplCloudflare;
+  } else if (*provider == "google") {
+    mode = kDohModeSecure;
+    templates = kTplGoogle;
+  } else if (*provider == "quad9") {
+    mode = kDohModeSecure;
+    templates = kTplQuad9;
+  } else if (*provider == "adguard") {
+    mode = kDohModeSecure;
+    templates = kTplAdguard;
+  } else {
+    // Unknown provider id: leave prefs untouched.
+    SendSettings();
+    return;
+  }
+
+  local_state->SetString(prefs::kDnsOverHttpsMode, mode);
+  local_state->SetString(prefs::kDnsOverHttpsTemplates, templates);
+  SendSettings();
+}
+
+void JahSettingsMessageHandler::HandleSetLang(const base::ListValue& args) {
+  if (!g_browser_process) {
+    SendSettings();
+    return;
+  }
+  PrefService* local_state = g_browser_process->local_state();
+  const std::string* locale =
+      args.size() > 0 ? args[0].GetIfString() : nullptr;
+  // Only accept the two locales the language switcher offers.
+  if (!local_state || !locale ||
+      (*locale != "tr" && *locale != "en-US")) {
+    SendSettings();
+    return;
+  }
+  // Takes effect after a browser relaunch.
+  local_state->SetString(language::prefs::kApplicationLocale, *locale);
+  SendSettings();
+}
+
+void JahSettingsMessageHandler::SendSettings() {
+  AllowJavascript();
+  Profile* profile = Profile::FromWebUI(web_ui());
+  PrefService* local_state =
+      g_browser_process ? g_browser_process->local_state() : nullptr;
+
+  base::DictValue state;
+  if (profile) {
+    PrefService* prefs = profile->GetPrefs();
+    state.Set("broadcastMode", prefs->GetBoolean(prefs::kJahBroadcastMode));
+    state.Set("forceDark",
+              prefs->GetBoolean(prefs::kWebKitForceDarkModeEnabled));
+  } else {
+    state.Set("broadcastMode", false);
+    state.Set("forceDark", false);
+  }
+  state.Set("adsBlocked",
+            local_state ? local_state->GetInteger(prefs::kJahBaltaAdsBlocked)
+                        : 0);
+  state.Set("dnsProvider", DeriveDnsProvider(local_state));
+
+  namespace ptp = performance_manager::user_tuning::prefs;
+  bool memory_saver =
+      local_state &&
+      local_state->GetInteger(ptp::kMemorySaverModeState) ==
+          static_cast<int>(ptp::MemorySaverModeState::kEnabled);
+  state.Set("memorySaver", memory_saver);
+
+  // JahBrowser feature on/off toggles (default true when unset).
+  state.Set("baltaEnabled",
+            local_state ? local_state->GetBoolean(prefs::kJahBaltaEnabled)
+                        : true);
+  state.Set("emotesEnabled",
+            local_state ? local_state->GetBoolean(prefs::kJahEmotesEnabled)
+                        : true);
+  state.Set("volumeBooster",
+            local_state ? local_state->GetBoolean(prefs::kJahVolumeBoosterEnabled)
+                        : true);
+
+  // Current application locale. Prefer the explicit user-selected pref; fall
+  // back to the resolved runtime locale when it has never been set.
+  std::string lang =
+      local_state ? local_state->GetString(language::prefs::kApplicationLocale)
+                  : std::string();
+  if (lang.empty() && g_browser_process) {
+    lang = g_browser_process->GetApplicationLocale();
+  }
+  state.Set("lang", lang);
+
+  web_ui()->CallJavascriptFunctionUnsafe("jahOnSettings",
+                                         base::Value(std::move(state)));
+}
diff --git a/chrome/browser/ui/webui/jah_settings/jah_settings_message_handler.h b/chrome/browser/ui/webui/jah_settings/jah_settings_message_handler.h
new file mode 100644
index 0000000000..146ba2dfc3
--- /dev/null
+++ b/chrome/browser/ui/webui/jah_settings/jah_settings_message_handler.h
@@ -0,0 +1,47 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_JAH_SETTINGS_JAH_SETTINGS_MESSAGE_HANDLER_H_
+#define CHROME_BROWSER_UI_WEBUI_JAH_SETTINGS_JAH_SETTINGS_MESSAGE_HANDLER_H_
+
+#include "content/public/browser/web_ui_message_handler.h"
+
+namespace base {
+class ListValue;
+}  // namespace base
+
+// WebUI message handler backing the JahBrowser control center
+// (chrome://jah-settings). It reads/writes a small set of profile + local_state
+// prefs and pushes the current snapshot back to the page via
+// window.jahOnSettings(state).
+//
+// chrome.send contract (page -> browser):
+//   "jahGetSettings"              -> reply jahOnSettings(state)
+//   "jahSetToggle" [name, bool]   -> set profile pref, reply jahOnSettings
+//   "jahSetDns"    [provider]     -> set DoH local_state prefs, reply jahOnSettings
+//   "jahSetLang"   [locale]       -> set app locale local_state pref, reply jahOnSettings
+// state = {broadcastMode, forceDark, adsBlocked, dnsProvider, lang}.
+// NOTE: locale changes require a browser relaunch to fully take effect.
+class JahSettingsMessageHandler : public content::WebUIMessageHandler {
+ public:
+  JahSettingsMessageHandler();
+  JahSettingsMessageHandler(const JahSettingsMessageHandler&) = delete;
+  JahSettingsMessageHandler& operator=(const JahSettingsMessageHandler&) =
+      delete;
+  ~JahSettingsMessageHandler() override;
+
+  // content::WebUIMessageHandler:
+  void RegisterMessages() override;
+
+ private:
+  void HandleGetSettings(const base::ListValue& args);
+  void HandleSetToggle(const base::ListValue& args);
+  void HandleSetDns(const base::ListValue& args);
+  void HandleSetLang(const base::ListValue& args);
+
+  // Pushes the current pref snapshot to the page via jahOnSettings(state).
+  void SendSettings();
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_JAH_SETTINGS_JAH_SETTINGS_MESSAGE_HANDLER_H_
