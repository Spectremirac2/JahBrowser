+
+  // content::WebUIMessageHandler:
+  void RegisterMessages() override;
+
+ private:
+  // Makes the (initially hidden) bubble widget visible via the controller's
+  // embedder ShowUI(). This is the availability handshake — without it the
+  // bubble never appears.
+  void HandleReady(const base::ListValue& args);
+  void HandleGet(const base::ListValue& args);
+  void HandleToggle(const base::ListValue& args);
+
+  void SendState();
+};
