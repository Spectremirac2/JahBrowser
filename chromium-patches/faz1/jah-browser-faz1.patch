+#ifndef CHROME_BROWSER_UI_WEBUI_JAH_SETTINGS_JAH_SETTINGS_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_JAH_SETTINGS_JAH_SETTINGS_UI_H_
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+
+class JahSettingsUI;
+
+// WebUIConfig for the JahBrowser "Kontrol Merkezi" control-center page
+// (chrome://jah-settings). Registered in
+// chrome/browser/ui/webui/chrome_web_ui_configs.cc.
+class JahSettingsUIConfig
+    : public content::DefaultWebUIConfig<JahSettingsUI> {
+ public:
+  JahSettingsUIConfig();
+};
+
+// WebUIController that serves the static JahBrowser control-center page. The
+// page is fully self-contained (tokens + styles + script inlined) and is served
+// directly from a request filter, so no grit/build_webui pipeline is required.
+// A JahSettingsMessageHandler backs the live toggles / DNS / Balta counter via
+// the chrome.send bridge (jahGetSettings / jahSetToggle / jahSetDns).
+class JahSettingsUI : public content::WebUIController {
+ public:
+  explicit JahSettingsUI(content::WebUI* web_ui);
+  JahSettingsUI(const JahSettingsUI&) = delete;
+  JahSettingsUI& operator=(const JahSettingsUI&) = delete;
+  ~JahSettingsUI() override;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_JAH_SETTINGS_JAH_SETTINGS_UI_H_
