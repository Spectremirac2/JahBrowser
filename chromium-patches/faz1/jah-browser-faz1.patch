+
+    <!-- (d) Arama Kısayolları -->
+    <div class="section">
+      <h2 data-i18n-tr="Arama Kısayolları" data-i18n-en="Search Shortcuts">Arama Kısayolları</h2>
+      <table class="shortcuts">
+        <thead>
+          <tr><th data-i18n-tr="Kısayol" data-i18n-en="Shortcut">Kısayol</th><th data-i18n-tr="Nereye gider" data-i18n-en="Goes to">Nereye gider</th></tr>
+        </thead>
+        <tbody>
+          <tr><td class="key">kick</td><td class="desc" data-i18n-tr="Kick'te ara / kanal aç" data-i18n-en="Search on Kick / open channel">Kick'te ara / kanal aç</td></tr>
+          <tr><td class="key">yt</td><td class="desc" data-i18n-tr="YouTube'da ara" data-i18n-en="Search on YouTube">YouTube'da ara</td></tr>
+          <tr><td class="key">tw</td><td class="desc" data-i18n-tr="Twitch'te ara / kanal aç" data-i18n-en="Search on Twitch / open channel">Twitch'te ara / kanal aç</td></tr>
+          <tr><td class="key">gh</td><td class="desc" data-i18n-tr="GitHub'da ara" data-i18n-en="Search on GitHub">GitHub'da ara</td></tr>
+          <tr><td class="key">wiki</td><td class="desc" data-i18n-tr="Wikipedia'da ara" data-i18n-en="Search on Wikipedia">Wikipedia'da ara</td></tr>
+        </tbody>
+      </table>
+    </div>
+
+    <!-- (e) Dil / Language -->
+    <div class="section">
+      <h2 data-i18n-tr="Dil / Language" data-i18n-en="Language / Dil">Dil / Language</h2>
+      <div class="seg" id="langSeg">
+        <button type="button" data-lang="tr">Türkçe</button>
+        <button type="button" data-lang="en-US">English</button>
+      </div>
+      <p class="cap" id="langNote" style="margin-top: var(--jah-space-3); color: var(--jah-text-muted); font-size: 13px;"
+         data-i18n-tr="Değişiklik için tarayıcıyı yeniden başlat."
+         data-i18n-en="Restart the browser to apply the change.">Değişiklik için tarayıcıyı yeniden başlat.</p>
+    </div>
+
+  </div>
+</div>
+
+<script>
+(function () {
+  "use strict";
+
+  // --- i18n: Türkçe varsayılan; navigator.language "en*" ise İngilizce ---
+  var JLANG = (navigator.language || "tr").toLowerCase().indexOf("tr") === 0
+      ? "tr" : "en";
+
+  function applyI18n() {
+    var nodes = document.querySelectorAll("[data-i18n-tr]");
+    for (var i = 0; i < nodes.length; i++) {
+      var el = nodes[i];
+      var val = JLANG === "en"
+          ? el.getAttribute("data-i18n-en")
+          : el.getAttribute("data-i18n-tr");
+      if (val !== null) { el.textContent = val; }
+    }
+    // aria-label çevirileri (metin taşımayan kontroller).
+    var labeled = document.querySelectorAll("[data-i18n-label-tr]");
+    for (var j = 0; j < labeled.length; j++) {
+      var le = labeled[j];
+      var lv = JLANG === "en"
+          ? le.getAttribute("data-i18n-label-en")
+          : le.getAttribute("data-i18n-label-tr");
+      if (lv !== null) { le.setAttribute("aria-label", lv); }
+    }
+    document.documentElement.setAttribute("lang", JLANG);
+    document.title = JLANG === "en"
+        ? "JahBrowser Control Center"
+        : "JahBrowser Kontrol Merkezi";
+  }
+  applyI18n();
+
+  // --- Toggle switches ---
+  function bindToggle(id, name) {
+    var el = document.getElementById(id);
+    if (!el) { return; }
+    function flip() {
+      var next = el.getAttribute("aria-checked") !== "true";
+      // Optimistic UI; browser confirms via jahOnSettings.
+      el.setAttribute("aria-checked", next ? "true" : "false");
+      chrome.send("jahSetToggle", [name, next]);
+    }
+    el.addEventListener("click", flip);
+    el.addEventListener("keydown", function (e) {
+      if (e.key === " " || e.key === "Enter") { e.preventDefault(); flip(); }
+    });
+  }
+  bindToggle("tgBroadcast", "broadcastMode");
+  bindToggle("tgDark", "forceDark");
+  bindToggle("tgMemory", "memorySaver");
+  bindToggle("tgBalta", "baltaEnabled");
+  bindToggle("tgEmotes", "emotesEnabled");
+  bindToggle("tgVolume", "volumeBooster");
+
+  // --- DNS segmented control ---
+  var dnsSeg = document.getElementById("dnsSeg");
+  if (dnsSeg) {
+    dnsSeg.addEventListener("click", function (e) {
+      var btn = e.target.closest("button[data-dns]");
+      if (!btn) { return; }
+      chrome.send("jahSetDns", [btn.getAttribute("data-dns")]);
+    });
+  }
+
+  function paintDns(provider) {
+    if (!dnsSeg) { return; }
+    var btns = dnsSeg.querySelectorAll("button[data-dns]");
+    for (var i = 0; i < btns.length; i++) {
+      btns[i].setAttribute("aria-pressed",
+          btns[i].getAttribute("data-dns") === provider ? "true" : "false");
+    }
+  }
+
+  // --- Language segmented control ---
+  var langSeg = document.getElementById("langSeg");
+  if (langSeg) {
+    langSeg.addEventListener("click", function (e) {
+      var btn = e.target.closest("button[data-lang]");
+      if (!btn) { return; }
+      chrome.send("jahSetLang", [btn.getAttribute("data-lang")]);
+    });
+  }
+
+  function paintLang(locale) {
+    if (!langSeg) { return; }
+    // "tr" -> tr butonu; diğer her şey (en, en-US, en-GB...) -> English.
+    var isTr = (locale || "").toLowerCase().indexOf("tr") === 0;
+    var btns = langSeg.querySelectorAll("button[data-lang]");
+    for (var i = 0; i < btns.length; i++) {
+      var isTrBtn = btns[i].getAttribute("data-lang") === "tr";
+      btns[i].setAttribute("aria-pressed",
+          (isTrBtn === isTr) ? "true" : "false");
+    }
+  }
+
+  // --- Browser -> page callback ---
+  window.jahOnSettings = function (s) {
+    if (!s) { return; }
+    var bc = document.getElementById("tgBroadcast");
+    if (bc) { bc.setAttribute("aria-checked", s.broadcastMode ? "true" : "false"); }
+    var dk = document.getElementById("tgDark");
+    if (dk) { dk.setAttribute("aria-checked", s.forceDark ? "true" : "false"); }
+    var ms = document.getElementById("tgMemory");
+    if (ms) { ms.setAttribute("aria-checked", s.memorySaver ? "true" : "false"); }
+    var bl = document.getElementById("tgBalta");
+    if (bl) { bl.setAttribute("aria-checked", s.baltaEnabled ? "true" : "false"); }
+    var em = document.getElementById("tgEmotes");
+    if (em) { em.setAttribute("aria-checked", s.emotesEnabled ? "true" : "false"); }
+    var vb = document.getElementById("tgVolume");
+    if (vb) { vb.setAttribute("aria-checked", s.volumeBooster ? "true" : "false"); }
+    var num = document.getElementById("adsNum");
+    if (num) { num.textContent = String(s.adsBlocked || 0); }
+    paintDns(s.dnsProvider || "auto");
+    paintLang(s.lang || "");
+  };
+
+  chrome.send("jahGetSettings");
+})();
+</script>
+
+</body>
+</html>
+)JAHSET"
