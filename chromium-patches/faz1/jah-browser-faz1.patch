diff --git a/chrome/browser/resources/side_panel/jah_live/jah_live_app.ts b/chrome/browser/resources/side_panel/jah_live/jah_live_app.ts
new file mode 100644
index 0000000000..3bcbecced7
--- /dev/null
+++ b/chrome/browser/resources/side_panel/jah_live/jah_live_app.ts
@@ -0,0 +1,233 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// JahBrowser — Kick live side panel bootstrap (mock data v1).
+//
+// This file is compiled to jah_live_app.js and loaded as an ES module by
+// jah_live.html. Because the WebUI data source enables Trusted Types
+// (require-trusted-types-for 'script'), this code MUST NOT assign strings to
+// innerHTML/outerHTML. All DOM is built with createElement()/textContent and
+// SVG icons are cloned via <use> created with createElementNS().
+
+export {};
+
+const SVG_NS = 'http://www.w3.org/2000/svg';
+const XLINK_NS = 'http://www.w3.org/1999/xlink';
+
+type Platform = 'kick'|'twitch';
+
+interface Channel {
+  name: string;
+  platform: Platform;
+  live: boolean;
+  viewers?: number;
+  category: string;
+  uptimeSec?: number;
+  lastSeen?: string;
+  palette: number;
+}
+
+// Avatar backgrounds use only chat user color tokens.
+const PALETTE: string[] = [
+  '--jah-chat-user-2', '--jah-chat-user-6', '--jah-chat-user-1',
+  '--jah-chat-user-5', '--jah-chat-user-7', '--jah-chat-user-4',
+  '--jah-chat-user-3', '--jah-chat-user-8'
+];
+
+const CHANNELS: Channel[] = [
+  {name: 'Elraenn', platform: 'kick', live: true, viewers: 23951,
+   category: 'League of Legends', uptimeSec: 5 * 3600 + 12 * 60 + 40, palette: 0},
+  {name: 'KendineMüzisyen', platform: 'twitch', live: true, viewers: 8104,
+   category: 'GTA V · Rockday RP', uptimeSec: 1 * 3600 + 58 * 60 + 6, palette: 1},
+  {name: 'Pqueen', platform: 'kick', live: true, viewers: 6742,
+   category: 'Sadece Sohbet', uptimeSec: 47 * 60 + 21, palette: 2},
+  {name: 'wtcN', platform: 'twitch', live: false, lastSeen: '5 sa önce',
+   category: 'Valorant', palette: 3},
+  {name: 'unlostv', platform: 'kick', live: false, lastSeen: 'dün',
+   category: 'CS2', palette: 4},
+  {name: 'Ferit', platform: 'twitch', live: false, lastSeen: '2 gün önce',
+   category: 'Sadece Sohbet', palette: 5}
+];
+
+const jahrein = {viewers: 12437, uptimeSec: 3 * 3600 + 42 * 60 + 18};
+
+function fmtViewersTR(n: number): string {
+  if (n >= 1000) {
+    const r = Math.round((n / 1000) * 10) / 10;
+    const frac = (r % 1 !== 0 && r < 100) ? 1 : 0;
+    return r.toLocaleString('tr-TR',
+        {minimumFractionDigits: frac, maximumFractionDigits: frac}) + ' B';
+  }
+  return n.toLocaleString('tr-TR');
+}
+
+function fmtUptime(sec: number): string {
+  const h = Math.floor(sec / 3600);
+  const m = Math.floor((sec % 3600) / 60);
+  const s = sec % 60;
+  const p = (x: number): string => (x < 10 ? '0' + x : '' + x);
+  return h > 0 ? h + ':' + p(m) + ':' + p(s) : m + ':' + p(s);
+}
+
+function initials(name: string): string {
+  return name.trim().charAt(0).toLocaleUpperCase('tr-TR');
+}
+
+function svgUse(iconId: string): SVGSVGElement {
+  const svg = document.createElementNS(SVG_NS, 'svg');
+  svg.setAttribute('aria-hidden', 'true');
+  const use = document.createElementNS(SVG_NS, 'use');
+  use.setAttribute('href', '#' + iconId);
+  use.setAttributeNS(XLINK_NS, 'xlink:href', '#' + iconId);
+  svg.appendChild(use);
+  return svg;
+}
+
+function buildAvatar(ch: Channel, sizeCls: string): HTMLDivElement {
+  const avatar = document.createElement('div');
+  avatar.className = 'avatar ' + sizeCls + (ch.live ? ' avatar--ring-live' : '');
+  const varName = PALETTE[ch.palette % PALETTE.length] ?? '--jah-chat-user-1';
+  avatar.style.background =
+      'linear-gradient(135deg, var(' + varName + '), var(--jah-surface-overlay))';
+  avatar.appendChild(document.createTextNode(initials(ch.name)));
+
+  const chip = document.createElement('span');
+  chip.className =
+      'platform-chip ' + (ch.platform === 'kick' ? 'platform-kick' : 'platform-twitch');
+  chip.title = ch.platform === 'kick' ? 'Kick' : 'Twitch';
+  chip.appendChild(svgUse(ch.platform === 'kick' ? 'i-kick' : 'i-twitch'));
+  avatar.appendChild(chip);
+  return avatar;
+}
+
+function buildRow(ch: Channel): HTMLButtonElement {
+  const row = document.createElement('button');
+  row.type = 'button';
+  row.className = 'channel-row' + (ch.live ? '' : ' channel-row--offline');
+  row.setAttribute('aria-label', ch.name + (ch.live ? ' canlı — izle' : ' çevrimdışı'));
+
+  row.appendChild(buildAvatar(ch, 'avatar--md'));
+
+  const main = document.createElement('div');
+  main.className = 'row-main';
+  const nameRow = document.createElement('div');
+  nameRow.className = 'row-name';
+  const nm = document.createElement('span');
+  nm.className = 'nm';
+  nm.textContent = ch.name;
+  nameRow.appendChild(nm);
+  const sub = document.createElement('div');
+  sub.className = 'row-sub';
+  sub.textContent = ch.live ? ch.category : 'Son yayın: ' + ch.category;
+  main.appendChild(nameRow);
+  main.appendChild(sub);
+  row.appendChild(main);
+
+  const meta = document.createElement('div');
+  meta.className = 'row-meta';
+  if (ch.live) {
+    const viewers = document.createElement('span');
+    viewers.className = 'row-viewers';
+    viewers.textContent = fmtViewersTR(ch.viewers ?? 0);
+    const uptime = document.createElement('span');
+    uptime.className = 'row-uptime';
+    uptime.textContent = fmtUptime(ch.uptimeSec ?? 0);
+    meta.appendChild(viewers);
+    meta.appendChild(uptime);
+  } else {
+    const since = document.createElement('span');
+    since.className = 'offline-since';
+    since.textContent = ch.lastSeen ?? '';
+    meta.appendChild(since);
+  }
+  row.appendChild(meta);
+  return row;
+}
+
+function render(): void {
+  const liveList = document.getElementById('liveList');
+  const offlineList = document.getElementById('offlineList');
+  const liveCount = document.getElementById('liveCount');
+  const offlineCount = document.getElementById('offlineCount');
+  const footer = document.getElementById('footerSummary');
+  if (!liveList || !offlineList || !liveCount || !offlineCount || !footer) {
+    return;
+  }
+
+  const liveChannels = CHANNELS.filter(c => c.live);
+  const offlineChannels = CHANNELS.filter(c => !c.live);
+
+  liveChannels.forEach(c => liveList.appendChild(buildRow(c)));
+  offlineChannels.forEach(c => offlineList.appendChild(buildRow(c)));
+
+  // +1 for the pinned Jahrein card.
+  liveCount.textContent = String(liveChannels.length + 1);
+  offlineCount.textContent = String(offlineChannels.length);
+
+  const totalLive = liveChannels.length + 1;
+  const totalFollowed = CHANNELS.length + 1;
+  const strong = document.createElement('b');
+  strong.textContent = totalLive + ' canlı';
+  footer.textContent = '';
+  footer.appendChild(strong);
+  footer.appendChild(
+      document.createTextNode(' · ' + totalFollowed + ' kanal takipte'));
+}
+
+function initPinnedCard(): void {
+  const avatar = document.getElementById('jahreinAvatar');
+  if (avatar) {
+    avatar.style.background =
+        'linear-gradient(135deg, var(--jah-accent-pressed), var(--jah-surface-overlay))';
+  }
+  const viewers = document.getElementById('jahreinViewers');
+  const uptime = document.getElementById('jahreinUptime');
+
+  const paint = (): void => {
+    if (viewers) {
+      viewers.textContent = fmtViewersTR(jahrein.viewers) + ' izleyici';
+      viewers.title = jahrein.viewers.toLocaleString('tr-TR') + ' izleyici';
+    }
+    if (uptime) {
+      uptime.textContent = fmtUptime(jahrein.uptimeSec);
+    }
+  };
+  paint();
+
+  window.setInterval(() => {
+    jahrein.uptimeSec += 1;
+    if (jahrein.uptimeSec % 5 === 0) {
+      jahrein.viewers += Math.round((Math.random() - 0.45) * 60);
+    }
+    paint();
+  }, 1000);
+}
+
+function initDensityToggle(): void {
+  const sidebar = document.querySelector<HTMLElement>('.sidebar');
+  const buttons =
+      Array.from(document.querySelectorAll<HTMLButtonElement>('.density-btn'));
+  buttons.forEach(btn => {
+    btn.addEventListener('click', () => {
+      const density = btn.getAttribute('data-density');
+      if (sidebar && density) {
+        sidebar.setAttribute('data-density', density);
+      }
+      buttons.forEach(
+          b => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
+    });
+  });
+}
+
+function main(): void {
+  render();
+  initPinnedCard();
+  initDensityToggle();
+}
+
+if (document.readyState === 'loading') {
+  document.addEventListener('DOMContentLoaded', main);
+} else {
+  main();
+}
