+#include "services/network/public/mojom/content_security_policy.mojom.h"
+
+namespace {
+
+constexpr char kJahVolumeBubblePage[] =
+#include "chrome/browser/ui/webui/jah_volume/resources/jah_volume_bubble_page.inc"
+    ;  // NOLINT(whitespace/semicolon)
+
+bool ShouldHandleRequest(const std::string& path) {
+  return true;
+}
+
+void HandleRequest(const std::string& path,
+                   content::WebUIDataSource::GotDataCallback callback) {
+  std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
+      std::string(kJahVolumeBubblePage)));
+}
+
+}  // namespace
+
+bool JahVolumeBubbleUIConfig::ShouldAutoResizeHost() {
+  return true;
+}
+
+JahVolumeBubbleUI::JahVolumeBubbleUI(content::WebUI* web_ui)
+    : TopChromeWebUIController(web_ui, /*enable_chrome_send=*/true) {
+  Profile* const profile = Profile::FromWebUI(web_ui);
+  content::WebUIDataSource* source = content::WebUIDataSource::CreateAndAdd(
+      profile, chrome::kChromeUIJahVolumeBubbleHost);
+
+  web_ui->AddMessageHandler(
+      std::make_unique<JahVolumeBubbleMessageHandler>());
+
+  source->SetRequestFilter(base::BindRepeating(&ShouldHandleRequest),
+                           base::BindRepeating(&HandleRequest));
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  source->DisableTrustedTypesCSP();
+}
+
+JahVolumeBubbleUI::~JahVolumeBubbleUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(JahVolumeBubbleUI)
