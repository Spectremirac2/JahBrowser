@@ -0,0 +1,134 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/jah/jah_crash_recovery_tab_helper.h"
+
+#include "build/build_config.h"
+#include "chrome/browser/browser_process.h"
+#include "content/public/browser/browser_task_traits.h"
+#include "content/public/browser/browser_thread.h"
+#include "content/public/browser/navigation_controller.h"
+#include "content/public/browser/navigation_entry.h"
+#include "content/public/browser/reload_type.h"
+#include "content/public/browser/web_contents.h"
+#include "url/gurl.h"
+
+namespace {
+
+// A tab that keeps crashing is genuinely broken; after this many crashes in the
+// backoff window we stop auto-reloading and let the sad tab show.
+constexpr int kMaxRecoveries = 5;
+
+// Crashes closer together than this count toward the backoff streak.
+constexpr base::TimeDelta kBackoffWindow = base::Seconds(30);
+
+bool IsStreamHost(const GURL& url) {
+  return url.SchemeIsHTTPOrHTTPS() &&
+         (url.DomainIs("kick.com") || url.DomainIs("twitch.tv"));
+}
+
+}  // namespace
+
+JahCrashRecoveryTabHelper::JahCrashRecoveryTabHelper(
+    content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<JahCrashRecoveryTabHelper>(*web_contents) {}
+
+JahCrashRecoveryTabHelper::~JahCrashRecoveryTabHelper() = default;
+
+bool JahCrashRecoveryTabHelper::IsRealCrash(
+    base::TerminationStatus status) const {
+  switch (status) {
+    case base::TERMINATION_STATUS_ABNORMAL_TERMINATION:
+    case base::TERMINATION_STATUS_PROCESS_WAS_KILLED:
+    case base::TERMINATION_STATUS_PROCESS_CRASHED:
+    case base::TERMINATION_STATUS_OOM:
+#if BUILDFLAG(IS_WIN)
+    case base::TERMINATION_STATUS_INTEGRITY_FAILURE:
+#endif
+      return true;
+    default:
+      // NORMAL_TERMINATION, STILL_RUNNING, LAUNCH_FAILED, and (importantly)
+      // memory-eviction paths are intentional — do not auto-reload those.
+      return false;
+  }
+}
+
+base::TimeDelta JahCrashRecoveryTabHelper::RecoverDelay() const {
+  base::TimeDelta backoff;
+  if (recent_crash_count_ <= 1) {
+    backoff = base::TimeDelta();
+  } else if (recent_crash_count_ == 2) {
+    backoff = base::Seconds(1);
+  } else if (recent_crash_count_ == 3) {
+    backoff = base::Seconds(3);
+  } else {
+    backoff = base::Seconds(10);
+  }
+  // Live stream tabs come back as fast as possible; other tabs get a small
+  // delay so a transient crash storm settles first.
+  const base::TimeDelta base_delay =
+      IsStreamHost(web_contents()->GetLastCommittedURL())
+          ? base::Milliseconds(50)
+          : base::Milliseconds(400);
+  return base_delay + backoff;
+}
+
+void JahCrashRecoveryTabHelper::PrimaryMainFrameRenderProcessGone(
+    base::TerminationStatus status) {
+  if (g_browser_process && g_browser_process->IsShuttingDown()) {
+    return;
+  }
+  if (!IsRealCrash(status)) {
+    return;
+  }
+
+  const base::TimeTicks now = base::TimeTicks::Now();
+  if (!last_crash_time_.is_null() && (now - last_crash_time_) <= kBackoffWindow) {
+    ++recent_crash_count_;
+  } else {
+    recent_crash_count_ = 1;
+  }
+  last_crash_time_ = now;
+
+  // Give up on a tab that keeps crashing; the sad tab will remain visible.
+  if (recent_crash_count_ > kMaxRecoveries) {
+    return;
+  }
+
+  // Never reload synchronously from inside the crash notification.
+  content::GetUIThreadTaskRunner({})->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&JahCrashRecoveryTabHelper::DoReload,
+                     weak_factory_.GetWeakPtr()),
+      RecoverDelay());
+}
+
+void JahCrashRecoveryTabHelper::DoReload() {
+  content::WebContents* wc = web_contents();
+  if (!wc || !wc->IsCrashed()) {
+    return;
+  }
+  // Skip auto-reload for POST results so we never silently re-submit a form;
+  // the user sees the sad tab and can decide.
+  content::NavigationEntry* entry =
+      wc->GetController().GetLastCommittedEntry();
+  if (entry && entry->GetHasPostData()) {
+    return;
+  }
+  wc->GetController().Reload(content::ReloadType::NORMAL,
+                            /*check_for_repost=*/false);
+}
+
+void JahCrashRecoveryTabHelper::DidStopLoading() {
+  // A tab that has loaded and stayed up past the backoff window is healthy
+  // again; forget the crash streak so a later isolated crash recovers fast.
+  if (!last_crash_time_.is_null() &&
+      (base::TimeTicks::Now() - last_crash_time_) > kBackoffWindow) {
+    recent_crash_count_ = 0;
+    last_crash_time_ = base::TimeTicks();
+  }
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(JahCrashRecoveryTabHelper);
