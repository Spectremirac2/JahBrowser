diff --git a/chrome/browser/jah/jah_balta_counter_host.cc b/chrome/browser/jah/jah_balta_counter_host.cc
new file mode 100644
index 0000000000..fdc22aacc5
--- /dev/null
+++ b/chrome/browser/jah/jah_balta_counter_host.cc
@@ -0,0 +1,60 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/jah/jah_balta_counter_host.h"
+
+#include <string>
+
+#include "base/strings/stringprintf.h"
+#include "base/time/time.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/common/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+
+namespace {
+
+// Returns today's local date as "YYYY-MM-DD", used as the daily-reset key.
+std::string TodayKey() {
+  base::Time::Exploded exploded;
+  base::Time::Now().LocalExplode(&exploded);
+  return base::StringPrintf("%04d-%02d-%02d", exploded.year, exploded.month,
+                            exploded.day_of_month);
+}
+
+}  // namespace
+
+JahBaltaCounterHost::JahBaltaCounterHost() = default;
+JahBaltaCounterHost::~JahBaltaCounterHost() = default;
+
+// static
+void JahBaltaCounterHost::Create(
+    mojo::PendingReceiver<chrome::mojom::JahBaltaCounterHost> receiver) {
+  mojo::MakeSelfOwnedReceiver(std::make_unique<JahBaltaCounterHost>(),
+                              std::move(receiver));
+}
+
+void JahBaltaCounterHost::ReportBlocked(uint32_t count) {
+  // Runs on the UI thread (BindHostReceiverForRenderer binds host receivers on
+  // the UI thread), so touching local_state() here is safe.
+  if (!g_browser_process) {
+    return;
+  }
+  PrefService* local_state = g_browser_process->local_state();
+  if (!local_state) {
+    return;
+  }
+
+  // Daily reset: zero the counter when the stored date is not today.
+  const std::string today = TodayKey();
+  if (local_state->GetString(prefs::kJahBaltaResetDate) != today) {
+    local_state->SetInteger(prefs::kJahBaltaAdsBlocked, 0);
+    local_state->SetString(prefs::kJahBaltaResetDate, today);
+  }
+
+  local_state->SetInteger(
+      prefs::kJahBaltaAdsBlocked,
+      local_state->GetInteger(prefs::kJahBaltaAdsBlocked) +
+          static_cast<int>(count));
+}
diff --git a/chrome/browser/jah/jah_balta_counter_host.h b/chrome/browser/jah/jah_balta_counter_host.h
new file mode 100644
index 0000000000..28dd841a09
--- /dev/null
+++ b/chrome/browser/jah/jah_balta_counter_host.h
@@ -0,0 +1,31 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_JAH_JAH_BALTA_COUNTER_HOST_H_
+#define CHROME_BROWSER_JAH_JAH_BALTA_COUNTER_HOST_H_
+
+#include "chrome/common/jah_balta.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+// Browser-process endpoint for the renderer-side Balta ad blocker. Each blocked
+// request is reported here and accumulated in local_state as a per-day total
+// (prefs::kJahBaltaAdsBlocked), which the jah-home NTP renders as the live
+// "reklam engellendi" counter. Must be created and used on the UI thread.
+class JahBaltaCounterHost : public chrome::mojom::JahBaltaCounterHost {
+ public:
+  JahBaltaCounterHost();
+  ~JahBaltaCounterHost() override;
+
+  JahBaltaCounterHost(const JahBaltaCounterHost&) = delete;
+  JahBaltaCounterHost& operator=(const JahBaltaCounterHost&) = delete;
+
+  // Binds a self-owned receiver on the UI thread.
+  static void Create(
+      mojo::PendingReceiver<chrome::mojom::JahBaltaCounterHost> receiver);
+
+  // chrome::mojom::JahBaltaCounterHost:
+  void ReportBlocked(uint32_t count) override;
+};
+
+#endif  // CHROME_BROWSER_JAH_JAH_BALTA_COUNTER_HOST_H_
