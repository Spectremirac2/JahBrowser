+void TabStyleViewsImpl::PaintJahActiveUnderline(gfx::Canvas* canvas) const {
+  // JahBrowser: a 2 DIP brand-accent (neon green) underline along the visible
+  // bottom edge of the *active* tab only. Selected-but-inactive and hovered
+  // tabs are intentionally excluded so the accent uniquely marks the
+  // foreground tab.
+  if (GetSelectionState() != TabStyle::TabSelectionState::kActive) {
+    return;
+  }
+
+  // Reuse the exact active-tab fill shape so the accent automatically follows
+  // the rounded bottom corners, split-tab geometry and RTL. This avoids any
+  // separate geometry math that could drift from GetPath().
+  const SkPath fill_path =
+      GetPath(TabStyle::PathType::kActiveTab, canvas->image_scale(), {});
+
+  gfx::ScopedCanvas scoped_canvas(canvas);
+  const float scale = canvas->UndoDeviceScaleFactor();
+
+  // Clip to the squircle: the accent can never bleed outside the tab shape,
+  // and the rounded bottom corners give the band rounded ends for free.
+  canvas->ClipPath(fill_path, true);
+
+  // The tab's local bounds include the toolbar overlap at the very bottom,
+  // which is hidden behind the toolbar. The visible bottom edge is that many
+  // DIP higher.
+  const float overlap =
+      GetLayoutConstant(LayoutConstant::kTabstripToolbarOverlap) * scale;
+
+  constexpr float kJahUnderlineThicknessDip = 2.0f;
+  const float thickness = kJahUnderlineThicknessDip * scale;
+
+  gfx::RectF bounds(tab_->GetLocalBounds());
+  bounds.Scale(scale);
+  const float visible_bottom = bounds.bottom() - overlap;
+
+  const gfx::RectF underline(bounds.x(), visible_bottom - thickness,
+                             bounds.width(), overlap + thickness);
+
+  cc::PaintFlags flags;
+  flags.setAntiAlias(true);
+  flags.setStyle(cc::PaintFlags::kFill_Style);
+  flags.setColor(kJahAccent);
+  canvas->DrawRect(underline, flags);
+}
