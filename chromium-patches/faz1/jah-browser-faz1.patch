@@ -0,0 +1,88 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/renderer/jah/jah_emote_injector.h"
+
+#include "base/command_line.h"
+#include "chrome/common/chrome_isolated_world_ids.h"
+#include "chrome/common/chrome_switches.h"
+#include "content/public/renderer/render_frame.h"
+#include "third_party/blink/public/platform/web_isolated_world_info.h"
+#include "third_party/blink/public/platform/web_security_origin.h"
+#include "third_party/blink/public/platform/web_string.h"
+#include "third_party/blink/public/web/web_document.h"
+#include "third_party/blink/public/web/web_local_frame.h"
+#include "third_party/blink/public/web/web_script_source.h"
+#include "url/gurl.h"
+
+namespace {
+
+// The bundled, pre-verified content script (jah_emotes_content.js), wrapped as
+// a C++ raw string literal.
+const char kJahEmoteScript[] =
+#include "chrome/renderer/jah/jah_emote_content.inc"
+    ;  // NOLINT
+
+// True for kick.com / *.kick.com and twitch.tv / *.twitch.tv.
+bool IsSupportedStreamingHost(const GURL& url) {
+  if (!url.SchemeIsHTTPOrHTTPS()) {
+    return false;
+  }
+  return url.DomainIs("kick.com") || url.DomainIs("twitch.tv");
+}
+
+}  // namespace
+
+JahEmoteInjector::JahEmoteInjector(content::RenderFrame* render_frame)
+    : content::RenderFrameObserver(render_frame) {}
+
+JahEmoteInjector::~JahEmoteInjector() = default;
+
+void JahEmoteInjector::DidDispatchDOMContentLoadedEvent() {
+  MaybeInject();
+}
+
+void JahEmoteInjector::DidFinishLoad() {
+  MaybeInject();
+}
+
+void JahEmoteInjector::MaybeInject() {
+  // Skipped when the user turned emotes off in the Kontrol Merkezi.
+  if (base::CommandLine::ForCurrentProcess()->HasSwitch(
+          switches::kJahDisableEmotes)) {
+    return;
+  }
+  if (!render_frame()->IsMainFrame()) {
+    return;
+  }
+  blink::WebLocalFrame* frame = render_frame()->GetWebFrame();
+  if (!frame) {
+    return;
+  }
+  GURL url(frame->GetDocument().Url());
+  if (!IsSupportedStreamingHost(url)) {
+    return;
+  }
+  // Run in a dedicated ISOLATED world (not the main world). Kick serves a
+  // script-src CSP that silently blocks main-world script injection. An
+  // isolated world with an EMPTY CSP runs outside the page CSP (the same
+  // mechanism content scripts and Chrome Translate use). The DOM is shared, so
+  // the script sees chat and its inserted emote <img>s are governed by the
+  // document's img-src (which allows cdn.7tv.app, verified). We give the world
+  // the frame's own origin so same-origin /api/v2 fetches keep working. The
+  // script self-guards against double-injection and handles SPA nav.
+  blink::WebIsolatedWorldInfo info;
+  info.human_readable_name = "JahEmotes";
+  info.security_origin = blink::WebSecurityOrigin::Create(url);
+  info.content_security_policy = blink::WebString::FromUtf8("");
+  blink::SetIsolatedWorldInfo(ISOLATED_WORLD_ID_JAH_EMOTES, info);
+  frame->ExecuteScriptInIsolatedWorld(
+      ISOLATED_WORLD_ID_JAH_EMOTES,
+      blink::WebScriptSource(blink::WebString::FromUtf8(kJahEmoteScript)),
+      blink::BackForwardCacheAware::kAllow);
+}
+
+void JahEmoteInjector::OnDestruct() {
+  delete this;
+}
