diff --git a/chrome/browser/ui/webui/jah_multi/resources/jah_multi_page.inc b/chrome/browser/ui/webui/jah_multi/resources/jah_multi_page.inc
new file mode 100644
index 0000000000..93bd9f4b9c
--- /dev/null
+++ b/chrome/browser/ui/webui/jah_multi/resources/jah_multi_page.inc
@@ -0,0 +1,476 @@
+R"JAHMULTI(<!DOCTYPE html>
+<html lang="tr">
+<head>
+<meta charset="UTF-8">
+<meta name="viewport" content="width=device-width, initial-scale=1.0">
+<title>JahBrowser Çoklu Yayın</title>
+<style>
+  :root {
+    color-scheme: dark;
+    --jah-bg: #0A0E13;
+    --jah-surface: #141C28;
+    --jah-surface-2: #1C2735;
+    --jah-border: #232E3B;
+    --jah-accent: #53FC18;
+    --jah-accent-dim: #3FBF14;
+    --jah-text: #E4E8ED;
+    --jah-text-dim: #8A94A0;
+    --jah-live: #FF4D4D;
+    --jah-radius: 12px;
+  }
+  * { box-sizing: border-box; }
+  html, body { height: 100%; }
+  body {
+    margin: 0;
+    background: var(--jah-bg);
+    color: var(--jah-text);
+    font-family: system-ui, "Segoe UI", Roboto, sans-serif;
+    display: flex;
+    flex-direction: column;
+    min-height: 100vh;
+  }
+
+  /* Ust bar */
+  .topbar {
+    display: flex;
+    align-items: center;
+    gap: 16px;
+    padding: 12px 18px;
+    background: var(--jah-surface);
+    border-bottom: 1px solid var(--jah-border);
+    flex-wrap: wrap;
+    position: sticky;
+    top: 0;
+    z-index: 20;
+  }
+  .brand {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+    font-weight: 700;
+    font-size: 16px;
+    letter-spacing: 0.2px;
+  }
+  .brand .dot {
+    width: 10px; height: 10px; border-radius: 50%;
+    background: var(--jah-accent);
+    box-shadow: 0 0 10px var(--jah-accent);
+  }
+  .brand .sub { color: var(--jah-text-dim); font-weight: 500; font-size: 13px; }
+  .spacer { flex: 1 1 auto; }
+
+  .layout-group {
+    display: inline-flex;
+    background: var(--jah-surface-2);
+    border: 1px solid var(--jah-border);
+    border-radius: 10px;
+    overflow: hidden;
+  }
+  .layout-group button {
+    background: transparent;
+    color: var(--jah-text-dim);
+    border: none;
+    padding: 8px 14px;
+    font-size: 13px;
+    font-weight: 600;
+    cursor: pointer;
+    transition: background 0.15s, color 0.15s;
+  }
+  .layout-group button + button { border-left: 1px solid var(--jah-border); }
+  .layout-group button:hover { color: var(--jah-text); }
+  .layout-group button.active {
+    background: var(--jah-accent);
+    color: #04140A;
+  }
+
+  .add-form {
+    display: inline-flex;
+    align-items: center;
+    gap: 6px;
+  }
+  .add-form input {
+    background: var(--jah-surface-2);
+    border: 1px solid var(--jah-border);
+    color: var(--jah-text);
+    border-radius: 8px;
+    padding: 8px 10px;
+    font-size: 13px;
+    width: 150px;
+    outline: none;
+  }
+  .add-form input:focus { border-color: var(--jah-accent-dim); }
+  .btn {
+    background: var(--jah-accent);
+    color: #04140A;
+    border: none;
+    border-radius: 8px;
+    padding: 8px 14px;
+    font-size: 13px;
+    font-weight: 700;
+    cursor: pointer;
+  }
+  .btn:hover { background: var(--jah-accent-dim); }
+  .btn.ghost {
+    background: var(--jah-surface-2);
+    color: var(--jah-text-dim);
+    border: 1px solid var(--jah-border);
+  }
+  .btn.ghost:hover { color: var(--jah-text); }
+
+  /* Grid */
+  .grid {
+    flex: 1 1 auto;
+    display: grid;
+    grid-template-columns: repeat(2, 1fr);
+    gap: 10px;
+    padding: 12px;
+    align-content: start;
+  }
+  .cell {
+    position: relative;
+    aspect-ratio: 16 / 9;
+    background: #000;
+    border: 1px solid var(--jah-border);
+    border-radius: var(--jah-radius);
+    overflow: hidden;
+    min-height: 0;
+  }
+  .cell iframe {
+    position: absolute;
+    inset: 0;
+    width: 100%;
+    height: 100%;
+    border: 0;
+    display: block;
+  }
+  .cell-overlay {
+    position: absolute;
+    top: 0; left: 0; right: 0;
+    display: flex;
+    align-items: center;
+    gap: 8px;
+    padding: 8px 10px;
+    background: linear-gradient(180deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0) 100%);
+    opacity: 0;
+    transition: opacity 0.15s;
+    pointer-events: none;
+    z-index: 2;
+  }
+  .cell:hover .cell-overlay { opacity: 1; pointer-events: auto; }
+  .cell-name {
+    font-weight: 700;
+    font-size: 13px;
+    text-shadow: 0 1px 3px rgba(0,0,0,0.8);
+    white-space: nowrap;
+    overflow: hidden;
+    text-overflow: ellipsis;
+  }
+  .cell-actions { margin-left: auto; display: flex; gap: 6px; }
+  .icon-btn {
+    background: rgba(20,22,25,0.85);
+    color: var(--jah-text);
+    border: 1px solid var(--jah-border);
+    border-radius: 7px;
+    padding: 5px 9px;
+    font-size: 12px;
+    font-weight: 600;
+    cursor: pointer;
+    line-height: 1;
+  }
+  .icon-btn:hover { border-color: var(--jah-accent-dim); color: var(--jah-accent); }
+  .icon-btn.muted { color: var(--jah-text-dim); }
+  .icon-btn.remove:hover { border-color: var(--jah-live); color: var(--jah-live); }
+
+  .empty {
+    flex: 1 1 auto;
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    justify-content: center;
+    gap: 10px;
+    color: var(--jah-text-dim);
+    text-align: center;
+    padding: 40px;
+  }
+  .empty .big { font-size: 18px; font-weight: 700; color: var(--jah-text); }
+
+  @media (max-width: 720px) {
+    .grid { grid-template-columns: 1fr !important; }
+    .add-form input { width: 110px; }
+  }
+</style>
+</head>
+<body>
+  <div class="topbar">
+    <div class="brand">
+      <img src="data:image/webp;base64," alt="" width="20" height="20" style="border-radius:5px;vertical-align:middle;margin-right:6px">
+      <span data-i18n-tr="Çoklu Yayın" data-i18n-en="Multistream">Çoklu Yayın</span>
+      <span class="sub" data-i18n-tr="Jahrein" data-i18n-en="Jahrein">Jahrein</span>
+    </div>
+    <div class="spacer"></div>
+    <div class="layout-group" id="layoutGroup">
+      <button type="button" data-cols="2" class="active">2 <span data-i18n-tr="sütun" data-i18n-en="cols">sütun</span></button>
+      <button type="button" data-cols="3">3 <span data-i18n-tr="sütun" data-i18n-en="cols">sütun</span></button>
+      <button type="button" data-cols="4">4 <span data-i18n-tr="sütun" data-i18n-en="cols">sütun</span></button>
+    </div>
+    <form class="add-form" id="addForm">
+      <input id="addInput" type="text" autocomplete="off"
+             data-ph-tr="kanal-adı" data-ph-en="channel-slug" placeholder="kanal-adı">
+      <button class="btn" type="submit" data-i18n-tr="+ Kanal ekle" data-i18n-en="+ Add channel">+ Kanal ekle</button>
+    </form>
+    <button class="btn ghost" id="resetBtn" type="button"
+            data-i18n-tr="Sıfırla" data-i18n-en="Reset">Sıfırla</button>
+  </div>
+
+  <div class="grid" id="grid"></div>
+
+<script>
+(function () {
+  "use strict";
+
+  var EN = (navigator.language || "tr").toLowerCase().indexOf("en") === 0;
+  var LK_EXTRA = "jah.multi.extra";
+  var LK_HIDDEN = "jah.multi.hidden";
+  var LK_COLS = "jah.multi.cols";
+
+  var STR = {
+    empty: EN ? "No channels to show" : "Gösterilecek kanal yok",
+    emptyHint: EN
+      ? "Add a Kick channel from the top bar to start watching."
+      : "İzlemeye başlamak için üst bardan bir Kick kanalı ekle.",
+    sound: EN ? "Sound" : "Sesi Aç",
+    mute: EN ? "Mute" : "Sesi Kapat",
+    remove: EN ? "Remove" : "Kaldır"
+  };
+
+  // data-i18n / data-ph statik cevirileri uygula.
+  function applyStatic() {
+    document.querySelectorAll("[data-i18n-tr]").forEach(function (el) {
+      var v = EN ? el.getAttribute("data-i18n-en") : el.getAttribute("data-i18n-tr");
+      if (v != null) { el.textContent = v; }
+    });
+    document.querySelectorAll("[data-ph-tr]").forEach(function (el) {
+      var v = EN ? el.getAttribute("data-ph-en") : el.getAttribute("data-ph-tr");
+      if (v != null) { el.setAttribute("placeholder", v); }
+    });
+    if (EN) { document.documentElement.setAttribute("lang", "en"); }
+  }
+
+  function readList(key) {
+    try {
+      var v = JSON.parse(localStorage.getItem(key) || "[]");
+      return Array.isArray(v) ? v : [];
+    } catch (e) { return []; }
+  }
+  function writeList(key, arr) {
+    try { localStorage.setItem(key, JSON.stringify(arr)); } catch (e) {}
+  }
+
+  // Kanal slug'ini guvenli hale getir: kick slug'lari kucuk harf, harf/rakam/_/-.
+  function cleanSlug(s) {
+    if (!s) { return ""; }
+    s = String(s).trim();
+    // URL yapistirilmissa son parcayi al.
+    var m = s.match(/kick\.com\/([^\/?#]+)/i);
+    if (m) { s = m[1]; }
+    s = s.replace(/^@+/, "");
+    // Turkce I/i sorununu onlemek icin tr-TR locale ile kucult.
+    s = s.toLocaleLowerCase("tr-TR");
+    s = s.replace(/[^a-z0-9_-]/g, "");
+    return s;
+  }
+
+  // Model.
+  var base = [];          // [{slug, display}] browserdan
+  var muteState = {};     // slug -> bool (true = muted)
+  var cols = parseInt(localStorage.getItem(LK_COLS) || "2", 10);
+  if (!(cols >= 1 && cols <= 4)) { cols = 2; }
+
+  var gridEl = document.getElementById("grid");
+
+  function effective() {
+    var hidden = {};
+    readList(LK_HIDDEN).forEach(function (s) { hidden[s] = true; });
+    var out = [];
+    var seen = {};
+    function push(slug, display) {
+      slug = cleanSlug(slug);
+      if (!slug || seen[slug] || hidden[slug]) { return; }
+      seen[slug] = true;
+      out.push({ slug: slug, display: display || slug });
+    }
+    base.forEach(function (c) { push(c.slug, c.display); });
+    readList(LK_EXTRA).forEach(function (s) { push(s, s); });
+    return out;
+  }
+
+  function playerSrc(slug, muted) {
+    var url = "https://player.kick.com/" + encodeURIComponent(slug) +
+              "?autoplay=true";
+    // NOTE: Kick embed player mute assumption — muted=true is appended to
+    // satisfy autoplay policy; unmuting reloads without it (user gesture).
+    if (muted) { url += "&muted=true"; }
+    return url;
+  }
+
+  function render() {
+    gridEl.innerHTML = "";
+    var list = effective();
+
+    if (!list.length) {
+      var empty = document.createElement("div");
+      empty.className = "empty";
+      var big = document.createElement("div");
+      big.className = "big";
+      big.textContent = STR.empty;
+      var hint = document.createElement("div");
+      hint.textContent = STR.emptyHint;
+      empty.appendChild(big);
+      empty.appendChild(hint);
+      gridEl.appendChild(empty);
+      return;
+    }
+
+    gridEl.style.gridTemplateColumns = "repeat(" + cols + ", 1fr)";
+
+    list.forEach(function (c) {
+      if (!(c.slug in muteState)) { muteState[c.slug] = true; }
+      var muted = muteState[c.slug];
+
+      var cell = document.createElement("div");
+      cell.className = "cell";
+
+      var frame = document.createElement("iframe");
+      frame.src = playerSrc(c.slug, muted);
+      frame.setAttribute("allow", "autoplay; fullscreen; picture-in-picture");
+      frame.setAttribute("allowfullscreen", "true");
+      frame.setAttribute("title", c.display);
+      cell.appendChild(frame);
+
+      var ov = document.createElement("div");
+      ov.className = "cell-overlay";
+
+      var name = document.createElement("span");
+      name.className = "cell-name";
+      name.textContent = c.display;
+      ov.appendChild(name);
+
+      var actions = document.createElement("div");
+      actions.className = "cell-actions";
+
+      var muteBtn = document.createElement("button");
+      muteBtn.type = "button";
+      muteBtn.className = "icon-btn" + (muted ? " muted" : "");
+      muteBtn.textContent = muted ? STR.sound : STR.mute;
+      muteBtn.addEventListener("click", function () {
+        muteState[c.slug] = !muteState[c.slug];
+        // Reload iframe with new mute param (Kick player has no reliable
+        // postMessage mute API for third-party embeds).
+        frame.src = playerSrc(c.slug, muteState[c.slug]);
+        muteBtn.classList.toggle("muted", muteState[c.slug]);
+        muteBtn.textContent = muteState[c.slug] ? STR.sound : STR.mute;
+      });
+      actions.appendChild(muteBtn);
+
+      var rm = document.createElement("button");
+      rm.type = "button";
+      rm.className = "icon-btn remove";
+      rm.textContent = "×";
+      rm.title = STR.remove;
+      rm.setAttribute("aria-label", STR.remove);
+      rm.addEventListener("click", function () {
+        // Extra ise extra'dan cikar; degilse hidden'a ekle.
+        var extra = readList(LK_EXTRA).map(cleanSlug);
+        var idx = extra.indexOf(c.slug);
+        if (idx >= 0) {
+          extra.splice(idx, 1);
+          writeList(LK_EXTRA, extra);
+        } else {
+          var hidden = readList(LK_HIDDEN);
+          if (hidden.indexOf(c.slug) < 0) {
+            hidden.push(c.slug);
+            writeList(LK_HIDDEN, hidden);
+          }
+        }
+        render();
+      });
+      actions.appendChild(rm);
+
+      ov.appendChild(actions);
+      cell.appendChild(ov);
+      gridEl.appendChild(cell);
+    });
+  }
+
+  // Layout butonlari.
+  document.getElementById("layoutGroup").addEventListener("click", function (e) {
+    var b = e.target.closest("button[data-cols]");
+    if (!b) { return; }
+    cols = parseInt(b.getAttribute("data-cols"), 10) || 2;
+    localStorage.setItem(LK_COLS, String(cols));
+    this.querySelectorAll("button").forEach(function (x) {
+      x.classList.toggle("active", x === b);
+    });
+    if (gridEl.querySelector(".cell")) {
+      gridEl.style.gridTemplateColumns = "repeat(" + cols + ", 1fr)";
+    }
+  });
+
+  // Kanal ekleme.
+  document.getElementById("addForm").addEventListener("submit", function (e) {
+    e.preventDefault();
+    var inp = document.getElementById("addInput");
+    var slug = cleanSlug(inp.value);
+    inp.value = "";
+    if (!slug) { return; }
+    // Gizliyse tekrar gorunur yap.
+    var hidden = readList(LK_HIDDEN).filter(function (s) { return s !== slug; });
+    writeList(LK_HIDDEN, hidden);
+    // Base'te yoksa extra'ya ekle.
+    var inBase = base.some(function (c) { return cleanSlug(c.slug) === slug; });
+    if (!inBase) {
+      var extra = readList(LK_EXTRA).map(cleanSlug);
+      if (extra.indexOf(slug) < 0) {
+        extra.push(slug);
+        writeList(LK_EXTRA, extra);
+      }
+    }
+    render();
+  });
+
+  // Sifirla: sayfa-yerel eklemeleri/gizlemeleri temizle.
+  document.getElementById("resetBtn").addEventListener("click", function () {
+    writeList(LK_EXTRA, []);
+    writeList(LK_HIDDEN, []);
+    render();
+  });
+
+  // Browserdan gelen kanal listesi.
+  window.jahOnChannels = function (list) {
+    base = [];
+    if (Array.isArray(list)) {
+      list.forEach(function (c) {
+        if (c && c.slug) {
+          base.push({ slug: c.slug, display: c.display || c.slug });
+        }
+      });
+    }
+    render();
+  };
+
+  // Set active layout button from saved cols.
+  document.querySelectorAll("#layoutGroup button[data-cols]").forEach(function (b) {
+    b.classList.toggle("active", parseInt(b.getAttribute("data-cols"), 10) === cols);
+  });
+
+  applyStatic();
+  render();  // Ilk bos/extra render; browser listesi gelince tazelenir.
+
+  if (window.chrome && chrome.send) {
+    chrome.send("jahMultiGetChannels");
+  }
+})();
+</script>
+</body>
+</html>
+)JAHMULTI"
