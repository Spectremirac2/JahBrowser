+R"JAHBALTA(<!DOCTYPE html>
+<html lang="tr">
+<head>
+<meta charset="UTF-8">
+<title>Balta</title>
+<style>
+  :root{
+    --void:#0A0E13; --bg2:#0C1119; --panel:#0E141D; --elev:#141C28; --line:#1E2835;
+    --line-soft:#172029; --green:#33D14A; --green-deep:#1E7E2C; --cyan:#43B4CE;
+    --red:#EB4A3A; --text:#E4E8ED; --dim:#8A94A0; --muted:#59636F; --muted2:#3A434E;
+    --mono:ui-monospace,"Cascadia Mono","Consolas",monospace; --sans:"Segoe UI",system-ui,sans-serif;
+    color-scheme:dark;
+  }
+  *{box-sizing:border-box;}
+  html,body{margin:0;}
+  body{width:322px;background:var(--panel);color:var(--text);font-family:var(--sans);-webkit-font-smoothing:antialiased;user-select:none;}
+  .head{display:flex;align-items:center;gap:9px;padding:12px 14px;border-bottom:1px solid var(--line);}
+  .head .mk{width:20px;height:20px;color:var(--green);display:grid;place-items:center;}
+  .head .mk svg{width:18px;height:18px;}
+  .head b{font-size:13.5px;font-weight:700;flex:1;}
+  .head .site{font-family:var(--mono);font-size:11px;color:var(--cyan);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
+  .power-wrap{display:flex;flex-direction:column;align-items:center;padding:20px 14px 6px;gap:9px;}
+  .power{width:78px;height:78px;border-radius:50%;display:grid;place-items:center;cursor:pointer;border:2px solid var(--green);
+    background:radial-gradient(circle at 50% 40%,rgba(51,209,74,.18),rgba(51,209,74,.05));
+    box-shadow:0 0 22px -4px rgba(51,209,74,.5),inset 0 0 18px -8px rgba(51,209,74,.6);transition:all .15s;}
+  .power svg{width:34px;height:34px;color:var(--green);}
+  .power.off{border-color:var(--muted);background:var(--elev);box-shadow:none;}
+  .power.off svg{color:var(--muted);}
+  .power-label{font-family:var(--mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--green);font-weight:700;}
+  .power.off ~ .power-label{color:var(--muted);}
+  .plabel-off{color:var(--muted)!important;}
+  .power-hint{font-size:11.5px;color:var(--muted);margin-top:-3px;text-align:center;}
+  .counts{display:flex;padding:8px 14px 12px;gap:10px;}
+  .count{flex:1;background:var(--bg2);border:1px solid var(--line-soft);border-radius:10px;padding:10px 12px;text-align:center;}
+  .count .n{font-size:22px;font-weight:750;color:var(--green);font-variant-numeric:tabular-nums;line-height:1;}
+  .count .n.tot{color:var(--text);}
+  .count .l{font-family:var(--mono);font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:5px;}
+  .ratio{margin:0 14px 6px;height:7px;border-radius:4px;overflow:hidden;display:flex;background:var(--bg2);}
+  .ratio i{display:block;height:100%;}
+  .ratio .b{background:var(--red);} .ratio .a{background:var(--green);}
+  .ratio-cap{font-family:var(--mono);font-size:10px;color:var(--muted);margin:0 14px 12px;display:flex;justify-content:space-between;}
+  .ratio-cap .r{color:var(--red);} .ratio-cap .g{color:var(--green);}
+  .foot{border-top:1px solid var(--line);}
+  .flinks{display:flex;gap:16px;padding:11px 14px;font-family:var(--mono);font-size:11px;}
+  .flinks a{color:var(--cyan);text-decoration:none;cursor:pointer;}
+  .flinks a:hover{text-decoration:underline;}
+</style>
+</head>
+<body>
+  <div class="head">
+    <span class="mk"><svg viewBox="0 0 24 24"><path d="M13.8 3.2c2.9.2 5.9 1.7 6.6 4.4.5 2-.6 4-2.6 4.6-2.2.7-4-.4-5.2-2l-1.2 1.2 6 6c.6.6.6 1.6 0 2.2l-.6.6c-.6.6-1.6.6-2.2 0l-6-6-4 4c-.5.5-1.3.5-1.8 0s-.5-1.3 0-1.8l9.3-9.3c-.2-1.6.3-3.5 1.7-3.9z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></span>
+    <b>Balta</b>
+    <span class="site" id="site">bu site</span>
+  </div>
+  <div class="power-wrap">
+    <div class="power" id="power" role="button" tabindex="0" title="Balta'yı aç/kapat">
+      <svg viewBox="0 0 24 24"><path d="M12 3v9M7.5 6.5a7 7 0 109 0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
+    </div>
+    <div class="power-label" id="plabel">AÇIK</div>
+    <div class="power-hint" id="phint">reklam ve izleyiciler engelleniyor</div>
+  </div>
+  <div class="counts">
+    <div class="count"><div class="n" id="cSess">0</div><div class="l">bu oturum</div></div>
+    <div class="count"><div class="n tot" id="cTot">0</div><div class="l">bugün</div></div>
+  </div>
+  <div class="ratio"><i class="b" id="rB" style="width:72%"></i><i class="a" id="rA" style="width:28%"></i></div>
+  <div class="ratio-cap" style="margin-bottom:14px"><span class="r" id="rBc">%72 engellendi</span><span class="g" id="rAc">%28 izin</span></div>
+
+<script>
+  var enabled = true;
+  function render(s){
+    if(!s) return;
+    enabled = s.enabled !== false;
+    var p = document.getElementById('power');
+    var pl = document.getElementById('plabel');
+    var ph = document.getElementById('phint');
+    p.classList.toggle('off', !enabled);
+    pl.textContent = enabled ? 'AÇIK' : 'KAPALI';
+    pl.classList.toggle('plabel-off', !enabled);
+    ph.textContent = enabled ? 'reklam ve izleyiciler engelleniyor' : 'reklamlar engellenmiyor';
+    var n = s.adsBlocked || 0;
+    document.getElementById('cSess').textContent = n.toLocaleString('tr-TR');
+    document.getElementById('cTot').textContent = n.toLocaleString('tr-TR');
+    // ratio bar dims when off
+    document.getElementById('rB').style.opacity = enabled ? '1' : '.3';
+    document.getElementById('rA').style.opacity = enabled ? '1' : '.3';
+  }
+  window.jahOnBalta = render;
+  document.getElementById('power').addEventListener('click', function(){
+    enabled = !enabled;
+    render({enabled: enabled, adsBlocked: parseInt((document.getElementById('cSess').textContent||'0').replace(/\D/g,''))||0});
+    chrome.send('jahToggleBalta', [enabled]);
+  });
+  document.addEventListener('DOMContentLoaded', function(){
+    chrome.send('jahBaltaReady');
+    chrome.send('jahGetBalta');
+  });
+  // Also fire immediately in case DOMContentLoaded already passed.
+  chrome.send('jahBaltaReady');
+  chrome.send('jahGetBalta');
+</script>
+</body>
+</html>
+)JAHBALTA"
