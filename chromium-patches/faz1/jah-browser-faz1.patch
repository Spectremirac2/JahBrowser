+
+    <div class="reassure rise rise-3">
+      <svg viewBox="0 0 24 24" aria-hidden="true">
+        <path d="M12 3l7 3v5c0 4.4-3 8.3-7 9-4-0.7-7-4.6-7-9V6l7-3z"></path>
+        <path d="M9 12l2 2 4-4"></path>
+      </svg>
+      <span data-i18n-tr="Sade mod: yapay zeka ve gereksiz her şey kapalı." data-i18n-en="Simple mode: AI and everything unnecessary is off.">Sade mod: yapay zeka ve gereksiz her şey kapalı.</span>
+    </div>
+
+    <div class="finish rise rise-4">
+      <button class="jah-btn jah-btn--primary" type="button" id="btnStart" data-i18n-tr="Başla" data-i18n-en="Get started">
