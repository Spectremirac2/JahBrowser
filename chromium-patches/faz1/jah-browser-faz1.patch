diff --git a/components/jah_balta/jah_host_matcher.cc b/components/jah_balta/jah_host_matcher.cc
new file mode 100644
index 0000000000..86b8699763
--- /dev/null
+++ b/components/jah_balta/jah_host_matcher.cc
@@ -0,0 +1,80 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "components/jah_balta/jah_host_matcher.h"
+
+#include <iterator>
+#include <string>
+
+#include "base/containers/flat_set.h"
+#include "base/no_destructor.h"
+
+namespace jah_balta {
+
+namespace {
+
+// Defines kJahBlockedHosts[] and kJahProtectedHosts[] (sorted, ASCII order).
+#include "components/jah_balta/jah_blocklist_data.inc"
+
+const base::flat_set<std::string_view>& BlockedSet() {
+  static const base::NoDestructor<base::flat_set<std::string_view>> set(
+      base::sorted_unique, std::begin(kJahBlockedHosts),
+      std::end(kJahBlockedHosts));
+  return *set;
+}
+
+const base::flat_set<std::string_view>& ProtectedSet() {
+  static const base::NoDestructor<base::flat_set<std::string_view>> set(
+      base::sorted_unique, std::begin(kJahProtectedHosts),
+      std::end(kJahProtectedHosts));
+  return *set;
+}
+
+// Returns true if `host` or any of its registrable suffixes is in `set`.
+// e.g. "x.doubleclick.net" checks "x.doubleclick.net", "doubleclick.net",
+// "net".
+bool MatchesSuffix(const base::flat_set<std::string_view>& set,
+                   std::string_view host) {
+  std::string_view suffix = host;
+  while (true) {
+    if (set.contains(suffix)) {
+      return true;
+    }
+    const size_t dot = suffix.find('.');
+    if (dot == std::string_view::npos) {
+      break;
+    }
+    suffix = suffix.substr(dot + 1);
+  }
+  return false;
+}
+
+}  // namespace
+
+bool ShouldBlockHost(std::string_view host) {
+  if (host.empty()) {
+    return false;
+  }
+
+  // ASCII-lowercase the host (hostnames are ASCII / punycode).
+  std::string lowered(host);
+  for (char& c : lowered) {
+    if (c >= 'A' && c <= 'Z') {
+      c = static_cast<char>(c + ('a' - 'A'));
+    }
+  }
+  std::string_view h(lowered);
+  // Drop a trailing dot on fully-qualified hostnames.
+  if (!h.empty() && h.back() == '.') {
+    h.remove_suffix(1);
+  }
+
+  // Whitelist wins: never block Kick/Twitch/stream/emote infra.
+  if (MatchesSuffix(ProtectedSet(), h)) {
+    return false;
+  }
+  return MatchesSuffix(BlockedSet(), h);
+}
+
+}  // namespace jah_balta
