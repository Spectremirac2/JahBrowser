+
+// Parses Twitch's public GQL response: a JSON array whose first element is
+// {"data":{"user":{profileImageURL, stream:{viewersCount, game:{displayName}}}}}
+// stream == null (or user == null) means offline. Twitch's public query does
+// not expose the session title here, so title stays empty.
+JahLiveStatus ParseTwitchResponse(const std::optional<std::string>& body) {
+  JahLiveStatus s;
+  if (!body) {
+    return s;  // ok = false -> "unknown" fallback.
+  }
+  std::optional<base::Value> root =
+      base::JSONReader::Read(*body, base::JSON_PARSE_RFC);
+  if (!root || !root->is_list() || root->GetList().empty() ||
+      !root->GetList().front().is_dict()) {
+    return s;  // Unexpected shape / integrity-token rejection HTML.
+  }
+  const base::DictValue* data = root->GetList().front().GetDict().FindDict("data");
+  if (!data) {
+    return s;
+  }
+  s.ok = true;
+  const base::DictValue* user = data->FindDict("user");
+  if (!user) {
+    return s;  // Unknown login -> treated as offline.
+  }
+  if (const std::string* pic = user->FindString("profileImageURL")) {
+    s.avatar_url = *pic;
+  }
+  const base::DictValue* stream = user->FindDict("stream");
+  if (!stream) {
+    s.is_live = false;  // stream == null -> offline.
+    return s;
+  }
+  s.is_live = true;
+  s.viewers = stream->FindInt("viewersCount").value_or(0);
+  if (const base::DictValue* game = stream->FindDict("game")) {
+    if (const std::string* n = game->FindString("displayName")) {
+      s.category = *n;
+    }
+  }
+  return s;
+}
+
+// Serializes the follow-list statuses (aligned with `defs`) into a JSON array
+// the page consumes as __JAH_FOLLOWS__.
+std::string BuildFollowsJson(const std::vector<FollowChannel>& defs,
+                             const std::vector<JahLiveStatus>& follows) {
+  std::string out = "[";
+  for (size_t i = 0; i < defs.size(); ++i) {
+    const JahLiveStatus& s = i < follows.size() ? follows[i] : JahLiveStatus();
+    if (i) {
+      out += ",";
+    }
+    out += "{\"name\":" + ToJsStringLiteral(defs[i].display);
+    out += ",\"slug\":" + ToJsStringLiteral(defs[i].slug);
+    out += ",\"platform\":" + ToJsStringLiteral(defs[i].platform);
+    out += ",\"live\":";
+    out += s.is_live ? "true" : "false";
+    out += ",\"viewers\":" + base::NumberToString(s.viewers);
+    out += ",\"category\":" + ToJsStringLiteral(s.category);
+    out += ",\"avatar\":" +
+           ToJsStringLiteral(BuildAvatarProxyUrl(s.avatar_url));
+    out += ",\"ok\":";
+    out += s.ok ? "true" : "false";
+    out += "}";
+  }
+  out += "]";
+  return out;
+}
+
+// Replaces each placeholder token in the served page with real values.
+std::string RenderJahHomePage(const JahLiveStatus& hero,
+                              const std::string& follows_json) {
+  std::string page(kJahHomePage);
+  const char* state =
+      !hero.ok ? "unknown" : (hero.is_live ? "live" : "offline");
+
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_OK__",
+                                         hero.ok ? "true" : "false");
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_LIVE_STATE__", state);
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_TITLE__",
+                                         ToJsStringLiteral(hero.title));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_VIEWERS__",
+                                         base::NumberToString(hero.viewers));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_CATEGORY__",
+                                         ToJsStringLiteral(hero.category));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_UPTIME__",
+                                         base::NumberToString(hero.uptime_min));
+  base::ReplaceFirstSubstringAfterOffset(
+      &page, 0, "__JAH_AVATAR__",
+      ToJsStringLiteral(BuildAvatarProxyUrl(hero.avatar_url)));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_FOLLOWS__",
+                                         follows_json);
+
+  // Real per-day Balta ad-block count from local_state (0 if unavailable).
+  int ads_blocked = 0;
+  if (g_browser_process && g_browser_process->local_state()) {
+    ads_blocked = g_browser_process->local_state()->GetInteger(
+        prefs::kJahBaltaAdsBlocked);
+  }
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_ADS_BLOCKED__",
+                                         base::NumberToString(ads_blocked));
+  return page;
+}
+
+// Self-owned: fetches the hero channel + the follow list concurrently in the
+// browser process (no CORS), then serves the page with live data injected.
+// Deletes itself once every loader has reported (each has a 5s timeout, so a
+// callback is guaranteed).
+class JahHomeLiveFetcher {
+ public:
+  static void Start(scoped_refptr<network::SharedURLLoaderFactory> factory,
+                    std::vector<FollowChannel> follows,
+                    content::WebUIDataSource::GotDataCallback callback) {
+    auto* self = new JahHomeLiveFetcher(std::move(factory), std::move(follows),
+                                        std::move(callback));
+    self->FetchAll();
+  }
+
+ private:
+  JahHomeLiveFetcher(scoped_refptr<network::SharedURLLoaderFactory> factory,
+                     std::vector<FollowChannel> follows,
+                     content::WebUIDataSource::GotDataCallback callback)
+      : factory_(std::move(factory)),
+        follows_def_(std::move(follows)),
+        callback_(std::move(callback)) {
+    // Index 0 is the hero; 1..N are the follow channels.
+    total_ = 1 + follows_def_.size();
+    results_.resize(total_);
+    loaders_.resize(total_);
+    is_twitch_.assign(total_, false);
+  }
+
+  void FetchAll() {
+    if (!factory_) {
+      Finish();
+      return;
+    }
+    pending_ = total_;
+    StartOne(0, kHeroChannel.slug, kHeroChannel.platform);
+    for (size_t i = 0; i < follows_def_.size(); ++i) {
+      StartOne(i + 1, follows_def_[i].slug, follows_def_[i].platform);
+    }
+  }
+
+  void StartOne(size_t idx,
+                std::string_view slug,
+                std::string_view platform) {
+    const bool twitch = platform == "twitch";
+    is_twitch_[idx] = twitch;
+
+    auto request = std::make_unique<network::ResourceRequest>();
+    request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+    request->headers.SetHeader(net::HttpRequestHeaders::kUserAgent,
+                               kBrowserUserAgent);
+    if (twitch) {
+      // Public web GQL: POST with the well-known public Client-Id, no cookies.
+      request->url = GURL(kTwitchGqlUrl);
+      request->method = "POST";
+      request->headers.SetHeader("Client-Id", kTwitchClientId);
+    } else {
+      request->url = GURL(KickChannelUrl(slug));
+      request->method = "GET";
+      request->headers.SetHeader(net::HttpRequestHeaders::kAccept,
+                                 "application/json");
+    }
+
+    loaders_[idx] = network::SimpleURLLoader::Create(
+        std::move(request),
+        twitch ? TwitchTrafficAnnotation() : KickTrafficAnnotation());
+    loaders_[idx]->SetTimeoutDuration(base::Seconds(5));
+    if (twitch) {
+      loaders_[idx]->AttachStringForUpload(TwitchGqlBody(slug),
+                                           "application/json");
+    }
+    loaders_[idx]->DownloadToString(
+        factory_.get(),
+        base::BindOnce(&JahHomeLiveFetcher::OnOne, base::Unretained(this), idx),
+        kMaxKickBytes);
+  }
+
+  void OnOne(size_t idx, std::optional<std::string> body) {
+    if (loaders_[idx]->NetError() == net::OK) {
+      results_[idx] = is_twitch_[idx] ? ParseTwitchResponse(body)
+                                      : ParseKickResponse(body);
+    }
+    if (--pending_ == 0) {
+      Finish();
+    }
+  }
+
+  void Finish() {
+    JahLiveStatus hero = results_.empty() ? JahLiveStatus() : results_[0];
+    std::vector<JahLiveStatus> follows;
+    for (size_t i = 1; i < results_.size(); ++i) {
+      follows.push_back(results_[i]);
+    }
+    std::move(callback_).Run(base::MakeRefCounted<base::RefCountedString>(
+        RenderJahHomePage(hero, BuildFollowsJson(follows_def_, follows))));
+    delete this;
+  }
+
+  scoped_refptr<network::SharedURLLoaderFactory> factory_;
+  std::vector<FollowChannel> follows_def_;
+  content::WebUIDataSource::GotDataCallback callback_;
+  std::vector<JahLiveStatus> results_;
+  std::vector<std::unique_ptr<network::SimpleURLLoader>> loaders_;
+  std::vector<bool> is_twitch_;
+  size_t total_ = 0;
+  size_t pending_ = 0;
+};
+
+// Cap proxied avatar bytes (~2 MB); avatars are tiny but be defensive.
+constexpr size_t kMaxAvatarBytes = 2 * 1024 * 1024;
+
+// 1x1 transparent PNG served for missing/rejected/failed avatars.
+constexpr uint8_t kTransparentPng[] = {
+    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A, 0x00, 0x00, 0x00, 0x0D,
+    0x49, 0x48, 0x44, 0x52, 0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
+    0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4, 0x89, 0x00, 0x00, 0x00,
+    0x0A, 0x49, 0x44, 0x41, 0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
+    0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00, 0x00, 0x00, 0x00, 0x49,
+    0x45, 0x4E, 0x44, 0xAE, 0x42, 0x60, 0x82};
+
+scoped_refptr<base::RefCountedMemory> TransparentPngBytes() {
+  return base::MakeRefCounted<base::RefCountedBytes>(
+      base::span<const uint8_t>(kTransparentPng));
+}
+
+// Only Kick's and Twitch's image CDNs may be proxied; every other host is
+// rejected. static-cdn.jtvnw.net serves Twitch profile images (jpg over https).
+bool IsKickAvatarUrl(const GURL& url) {
+  return url.is_valid() && url.SchemeIs("https") &&
+         (url.host() == "files.kick.com" || url.host() == "images.kick.com" ||
+          url.host() == "static-cdn.jtvnw.net");
+}
+
+// Self-owned single-shot loader: GETs one Kick avatar in the browser process
+// (no CORS) and serves the raw bytes back via the data source, or a transparent
+// PNG on any failure. Deletes itself once the callback has run.
+class JahAvatarProxy {
+ public:
+  static void Start(scoped_refptr<network::SharedURLLoaderFactory> factory,
+                    const GURL& image_url,
+                    content::WebUIDataSource::GotDataCallback callback) {
+    (new JahAvatarProxy(image_url, std::move(callback)))
+        ->Fetch(std::move(factory));
+  }
+
+ private:
+  JahAvatarProxy(const GURL& image_url,
+                 content::WebUIDataSource::GotDataCallback callback)
+      : image_url_(image_url), callback_(std::move(callback)) {}
+
+  void Fetch(scoped_refptr<network::SharedURLLoaderFactory> factory) {
+    if (!factory) {
+      Serve(TransparentPngBytes());
+      return;
+    }
+    auto request = std::make_unique<network::ResourceRequest>();
+    request->url = image_url_;
+    request->method = "GET";
+    request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+    request->headers.SetHeader(net::HttpRequestHeaders::kUserAgent,
+                               kBrowserUserAgent);
+    loader_ = network::SimpleURLLoader::Create(std::move(request),
+                                               KickTrafficAnnotation());
+    loader_->SetTimeoutDuration(base::Seconds(5));
+    loader_->DownloadToString(
+        factory.get(),
+        base::BindOnce(&JahAvatarProxy::OnLoaded, base::Unretained(this)),
+        kMaxAvatarBytes);
+  }
+
+  void OnLoaded(std::optional<std::string> body) {
+    if (loader_->NetError() == net::OK && body && !body->empty()) {
+      Serve(base::MakeRefCounted<base::RefCountedString>(std::move(*body)));
+    } else {
+      Serve(TransparentPngBytes());
+    }
+  }
+
+  void Serve(scoped_refptr<base::RefCountedMemory> bytes) {
+    std::move(callback_).Run(std::move(bytes));
+    delete this;
+  }
+
+  GURL image_url_;
+  content::WebUIDataSource::GotDataCallback callback_;
+  std::unique_ptr<network::SimpleURLLoader> loader_;
+};
+
+// Serve the single page for every request path (the page references no
+// external sub-resources).
+bool ShouldHandleJahHomeRequest(const std::string& path) {
+  return true;
+}
