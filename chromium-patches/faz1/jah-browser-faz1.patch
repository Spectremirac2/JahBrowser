@@ -0,0 +1,80 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/jah_multi/jah_multi_message_handler.h"
+
+#include <string>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/web_ui.h"
+
+namespace {
+
+// Appends a {slug, display} entry to the outgoing channel list.
+void AddChannel(base::ListValue& out,
+                const std::string& slug,
+                const std::string& display) {
+  base::DictValue dict;
+  dict.Set("slug", slug);
+  dict.Set("display", display.empty() ? slug : display);
+  out.Append(std::move(dict));
+}
+
+}  // namespace
+
+JahMultiMessageHandler::JahMultiMessageHandler() = default;
+JahMultiMessageHandler::~JahMultiMessageHandler() = default;
+
+void JahMultiMessageHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "jahMultiGetChannels",
+      base::BindRepeating(&JahMultiMessageHandler::HandleGetChannels,
+                          base::Unretained(this)));
+}
+
+void JahMultiMessageHandler::HandleGetChannels(const base::ListValue& args) {
+  AllowJavascript();
+
+  base::ListValue list;
+  // Pinned hero channel is always first.
+  AddChannel(list, "jahrein", "Jahrein");
+
+  // Append the user's Kick follows from prefs (Twitch entries are skipped:
+  // the grid embeds Kick's player only). Malformed entries are ignored.
+  Profile* profile = Profile::FromWebUI(web_ui());
+  if (profile) {
+    PrefService* prefs = profile->GetPrefs();
+    if (prefs) {
+      const base::ListValue& follows =
+          prefs->GetList(prefs::kJahFollowChannels);
+      for (const base::Value& v : follows) {
+        const base::DictValue* d = v.GetIfDict();
+        if (!d) {
+          continue;
+        }
+        const std::string* slug = d->FindString("slug");
+        if (!slug || slug->empty()) {
+          continue;
+        }
+        const std::string* platform = d->FindString("platform");
+        // Skip Twitch follows; Kick is the default when unset.
+        if (platform && *platform == "twitch") {
+          continue;
+        }
+        if (*slug == "jahrein") {
+          continue;  // Already pinned first.
+        }
+        const std::string* display = d->FindString("display");
+        AddChannel(list, *slug, display ? *display : std::string());
+      }
+    }
+  }
+
+  web_ui()->CallJavascriptFunctionUnsafe("jahOnChannels",
+                                         base::Value(std::move(list)));
+}
