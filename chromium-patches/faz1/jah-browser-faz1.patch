diff --git a/chrome/renderer/jah/jah_balta_reporter.cc b/chrome/renderer/jah/jah_balta_reporter.cc
new file mode 100644
index 0000000000..ac7760f5e9
--- /dev/null
+++ b/chrome/renderer/jah/jah_balta_reporter.cc
@@ -0,0 +1,42 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/renderer/jah/jah_balta_reporter.h"
+
+#include "base/no_destructor.h"
+#include "chrome/common/jah_balta.mojom.h"
+#include "content/public/renderer/render_thread.h"
+#include "mojo/public/cpp/bindings/remote.h"
+
+namespace jah_balta {
+
+namespace {
+
+// Process-global remote to the browser-side counter host, lazily bound on the
+// render thread and re-bound if the pipe disconnects.
+mojo::Remote<chrome::mojom::JahBaltaCounterHost>& GetRemote() {
+  static base::NoDestructor<mojo::Remote<chrome::mojom::JahBaltaCounterHost>>
+      remote;
+  if (!remote->is_bound()) {
+    content::RenderThread::Get()->BindHostReceiver(
+        remote->BindNewPipeAndPassReceiver());
+    // Allow re-binding on the next call if the browser drops the pipe.
+    remote->reset_on_disconnect();
+  }
+  return *remote;
+}
+
+}  // namespace
+
+void ReportBlocked() {
+  if (!content::RenderThread::Get()) {
+    return;
+  }
+  auto& remote = GetRemote();
+  if (remote.is_bound()) {
+    remote->ReportBlocked(1);
+  }
+}
+
+}  // namespace jah_balta
