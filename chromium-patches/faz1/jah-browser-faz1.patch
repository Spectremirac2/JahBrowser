+      renderJahrein();
+    }, 1000);
+  } else {
+    // Cevrimdisi / bilinmiyor: sabit karti soluklastir, canli istatistikleri gizle.
+    if (pinnedCard) {
+      pinnedCard.classList.add("pinned-card--off");
+    }
+    if (jahBadge) {
+      jahBadge.textContent =
+        (JAH_LIVE.state === "unknown") ? "Bilinmiyor" : "Çevrimdışı";
+    }
+    jahViewers.style.display = "none";
+    if (jahUptimeStat) {
+      jahUptimeStat.style.display = "none";
+    }
+    if (!JAH_LIVE.category) {
+      jahCat.textContent = "Şu an yayında değil";
+    }
+  }
+})();
+</script>
+</body>
+</html>
+)JAHLIVE"
