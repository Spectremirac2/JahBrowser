+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_JAH_MULTI_JAH_MULTI_MESSAGE_HANDLER_H_
+#define CHROME_BROWSER_UI_WEBUI_JAH_MULTI_JAH_MULTI_MESSAGE_HANDLER_H_
+
+#include "content/public/browser/web_ui_message_handler.h"
+
+namespace base {
+class ListValue;
+}  // namespace base
+
+// WebUI message handler backing the JahBrowser multistream grid
+// (chrome://jah-multi). Read-only: it supplies the initial channel list
+// (pinned hero + the user's Kick follows) so the page can prefill its grid.
+// Page-local additions/removals are kept in the page's own localStorage.
+//
+// chrome.send contract (page -> browser):
+//   "jahMultiGetChannels" -> reply jahOnChannels(list)
+// list = [{slug, display}, ...], Kick channels only, "jahrein" always first.
+class JahMultiMessageHandler : public content::WebUIMessageHandler {
+ public:
+  JahMultiMessageHandler();
+  JahMultiMessageHandler(const JahMultiMessageHandler&) = delete;
+  JahMultiMessageHandler& operator=(const JahMultiMessageHandler&) = delete;
+  ~JahMultiMessageHandler() override;
+
+  // content::WebUIMessageHandler:
+  void RegisterMessages() override;
+
+ private:
+  void HandleGetChannels(const base::ListValue& args);
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_JAH_MULTI_JAH_MULTI_MESSAGE_HANDLER_H_
