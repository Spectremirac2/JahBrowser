+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_JAH_HOME_JAH_HOME_MESSAGE_HANDLER_H_
+#define CHROME_BROWSER_UI_WEBUI_JAH_HOME_JAH_HOME_MESSAGE_HANDLER_H_
+
+#include "content/public/browser/web_ui_message_handler.h"
+
+namespace base {
+class Value;
+}  // namespace base
+
+// WebUI message handler backing the editable follow list on chrome://jah-home
+// (and reused by the Kick live side panel page). It reads/writes the
+// prefs::kJahFollowChannels list pref on the active profile and pushes the
+// current list back to the page via window.jahOnFollows(list).
+//
+// chrome.send contract (page -> browser):
+//   "jahGetFollows"                        -> reply jahOnFollows(list)
+//   "jahAddFollow"  [slug, platform, display] -> add, reply jahOnFollows(list)
+//   "jahRemoveFollow" [slug]               -> remove, reply jahOnFollows(list)
+// list = JSON array of {slug, platform, display}.
+class JahHomeMessageHandler : public content::WebUIMessageHandler {
+ public:
+  JahHomeMessageHandler();
+  JahHomeMessageHandler(const JahHomeMessageHandler&) = delete;
+  JahHomeMessageHandler& operator=(const JahHomeMessageHandler&) = delete;
+  ~JahHomeMessageHandler() override;
+
+  // content::WebUIMessageHandler:
+  void RegisterMessages() override;
+
+ private:
+  void HandleGetFollows(const base::ListValue& args);
+  void HandleAddFollow(const base::ListValue& args);
+  void HandleRemoveFollow(const base::ListValue& args);
+
+  // Pushes the current pref list to the page via jahOnFollows(list).
+  void SendFollows();
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_JAH_HOME_JAH_HOME_MESSAGE_HANDLER_H_
