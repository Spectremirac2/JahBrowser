+    color: var(--jah-accent);
+    font-weight: 600;
+    width: 70px;
+  }
+  table.shortcuts td.desc { color: var(--jah-text-dim); }
+
+  @media (max-width: 520px) {
+    .section { padding: var(--jah-space-4); }
+    h1 { font-size: 22px; line-height: 28px; }
+  }
+</style>
+</head>
+<body>
