+void HandleJahHomeRequest(content::BrowserContext* browser_context,
+                          const std::string& path,
+                          content::WebUIDataSource::GotDataCallback callback) {
+  scoped_refptr<network::SharedURLLoaderFactory> factory;
+  if (browser_context) {
+    factory = browser_context->GetDefaultStoragePartition()
+                  ->GetURLLoaderFactoryForBrowserProcess();
+  }
+
+  // Same-origin avatar proxy: chrome://jah-home/jahavatar.png?u=<kick url>.
+  if (base::StartsWith(path, "jahavatar", base::CompareCase::SENSITIVE)) {
+    GURL request_url(std::string("chrome://")
+                         .append(chrome::kChromeUIJahHomeHost)
+                         .append("/")
+                         .append(path));
+    std::string decoded;
+    GURL image_url;
+    if (net::GetValueForKeyInQuery(request_url, "u", &decoded)) {
+      image_url = GURL(decoded);
+    }
+    if (!IsKickAvatarUrl(image_url)) {
+      std::move(callback).Run(TransparentPngBytes());
+      return;
+    }
+    JahAvatarProxy::Start(std::move(factory), image_url, std::move(callback));
+    return;
+  }
+
+  // Resolve the user-editable follow list from the profile pref (or default).
+  PrefService* prefs = nullptr;
+  if (Profile* profile = Profile::FromBrowserContext(browser_context)) {
+    prefs = profile->GetPrefs();
+  }
+  JahHomeLiveFetcher::Start(std::move(factory), ReadFollowChannels(prefs),
+                            std::move(callback));
+}
+
+}  // namespace
+
+JahHomeUIConfig::JahHomeUIConfig()
+    : DefaultWebUIConfig(content::kChromeUIScheme,
+                         chrome::kChromeUIJahHomeHost) {}
+
+JahHomeUI::JahHomeUI(content::WebUI* web_ui) : content::WebUIController(web_ui) {
+  content::BrowserContext* browser_context =
+      web_ui->GetWebContents()->GetBrowserContext();
+  content::WebUIDataSource* source = content::WebUIDataSource::CreateAndAdd(
+      browser_context, chrome::kChromeUIJahHomeHost);
+
+  // Backs the editable follow list (jahGetFollows/jahAddFollow/jahRemoveFollow).
+  web_ui->AddMessageHandler(std::make_unique<JahHomeMessageHandler>());
+
+  source->SetRequestFilter(
+      base::BindRepeating(&ShouldHandleJahHomeRequest),
+      base::BindRepeating(&HandleJahHomeRequest,
+                          base::Unretained(browser_context)));
+
+  // The page uses inline <style>/<script> and assigns to Element.innerHTML.
+  // Relax the default Trusted-WebUI CSP accordingly for this first-party page.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  // Allow real Kick + Twitch avatar images (served from their CDNs) plus data:.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ImgSrc,
+      "img-src 'self' https://files.kick.com https://images.kick.com "
+      "https://static-cdn.jtvnw.net data:;");
+  source->DisableTrustedTypesCSP();
+}
+
+JahHomeUI::~JahHomeUI() = default;
