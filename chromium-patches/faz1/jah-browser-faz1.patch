+// found in the LICENSE file.
+
+#include "chrome/renderer/jah/jah_balta_throttle.h"
+
+#include "chrome/renderer/jah/jah_balta_reporter.h"
+#include "components/jah_balta/jah_host_matcher.h"
+#include "net/base/net_errors.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "url/gurl.h"
+
+JahBaltaThrottle::JahBaltaThrottle() = default;
+JahBaltaThrottle::~JahBaltaThrottle() = default;
+
+void JahBaltaThrottle::WillStartRequest(network::ResourceRequest* request,
+                                        bool* defer) {
+  if (!request->url.SchemeIsHTTPOrHTTPS()) {
+    return;
+  }
+  if (jah_balta::ShouldBlockHost(request->url.host())) {
+    delegate_->CancelWithError(net::ERR_BLOCKED_BY_CLIENT, "JahBalta");
+    jah_balta::ReportBlocked();
+  }
+}
