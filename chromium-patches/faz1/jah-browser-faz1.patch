+++ b/chrome/browser/jah/jah_crash_recovery_tab_helper.h
@@ -0,0 +1,58 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_JAH_JAH_CRASH_RECOVERY_TAB_HELPER_H_
+#define CHROME_BROWSER_JAH_JAH_CRASH_RECOVERY_TAB_HELPER_H_
+
+#include "base/memory/weak_ptr.h"
+#include "base/process/kill.h"
+#include "base/time/time.h"
+#include "content/public/browser/web_contents_observer.h"
+#include "content/public/browser/web_contents_user_data.h"
+
+// JahBrowser: automatically recovers a tab whose renderer process crashed by
+// reloading it in a fresh process, instead of leaving the user on Chrome's
+// "Aw Snap" sad tab. This is a core JahBrowser stability promise — the browser
+// should not crash out from under a viewer, especially while watching a live
+// stream. Kick/Twitch tabs recover fastest. Repeated crashes in a short window
+// back off exponentially and eventually give up, so a genuinely broken page is
+// not stuck in an infinite reload loop (the sad tab shows in that case).
+//
+// This never conflicts with the "live stream tab is never discarded" rule: a
+// reload of an already-crashed tab is not a discard, and crashes are distinct
+// from intentional termination / memory eviction (which are ignored here).
+class JahCrashRecoveryTabHelper
+    : public content::WebContentsObserver,
+      public content::WebContentsUserData<JahCrashRecoveryTabHelper> {
+ public:
+  JahCrashRecoveryTabHelper(const JahCrashRecoveryTabHelper&) = delete;
+  JahCrashRecoveryTabHelper& operator=(const JahCrashRecoveryTabHelper&) =
+      delete;
+  ~JahCrashRecoveryTabHelper() override;
+
+  // content::WebContentsObserver:
+  void PrimaryMainFrameRenderProcessGone(
+      base::TerminationStatus status) override;
+  void DidStopLoading() override;
+
+ private:
+  explicit JahCrashRecoveryTabHelper(content::WebContents* web_contents);
+  friend class content::WebContentsUserData<JahCrashRecoveryTabHelper>;
+
+  // True only for genuine crashes (not intentional termination / eviction).
+  bool IsRealCrash(base::TerminationStatus status) const;
+  // Delay before reloading; short for stream tabs, plus crash backoff.
+  base::TimeDelta RecoverDelay() const;
+  void DoReload();
+
+  // Number of crashes within the recent backoff window.
+  int recent_crash_count_ = 0;
+  base::TimeTicks last_crash_time_;
+
+  base::WeakPtrFactory<JahCrashRecoveryTabHelper> weak_factory_{this};
+
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+#endif  // CHROME_BROWSER_JAH_JAH_CRASH_RECOVERY_TAB_HELPER_H_
diff --git a/chrome/browser/jah/jah_golive_service.cc b/chrome/browser/jah/jah_golive_service.cc
new file mode 100644
index 0000000000..f4e9843ca4
--- /dev/null
+++ b/chrome/browser/jah/jah_golive_service.cc
@@ -0,0 +1,263 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/jah/jah_golive_service.h"
+
+#include <array>
+#include <optional>
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/strings/strcat.h"
+#include "base/strings/utf_string_conversions.h"
+#include "base/values.h"
+#include "chrome/browser/notifications/notification_display_service.h"
+#include "chrome/browser/notifications/notification_display_service_factory.h"
+#include "chrome/browser/notifications/notification_handler.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/navigator/browser_navigator.h"
+#include "chrome/browser/ui/navigator/browser_navigator_params.h"
+#include "content/public/browser/storage_partition.h"
+#include "net/base/net_errors.h"
+#include "net/http/http_request_headers.h"
+#include "net/traffic_annotation/network_traffic_annotation.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "services/network/public/cpp/shared_url_loader_factory.h"
+#include "services/network/public/cpp/simple_url_loader.h"
+#include "ui/base/models/image_model.h"
+#include "ui/base/page_transition_types.h"
+#include "ui/base/window_open_disposition.h"
+#include "ui/message_center/public/cpp/notification.h"
+#include "ui/message_center/public/cpp/notification_delegate.h"
+#include "ui/message_center/public/cpp/notification_types.h"
+#include "ui/message_center/public/cpp/notifier_id.h"
+#include "url/gurl.h"
+
+namespace {
+
+// A watched Kick channel: lowercase slug + user-facing display name.
+struct Channel {
+  const char* slug;
+  const char* display_name;
+};
+
+// Jahrein (pinned hero) plus the same curated follow list surfaced in
+// jah_home_ui.cc. A real per-user followed list is a later step; for now every
+// JahBrowser watches the same set.
+constexpr std::array<Channel, 7> kChannels = {{
+    {"jahrein", "Jahrein"},
+    {"pqueen", "Pqueen"},
+    {"wtcn", "wtcN"},
+    {"elraenn", "Elraenn"},
+    {"elwind", "Elwind"},
+    {"kendinemuzisyen", "KendineMuzisyen"},
+    {"mithrain", "Mithrain"},
+}};
+
+constexpr base::TimeDelta kPollInterval = base::Seconds(60);
+constexpr size_t kMaxKickBytes = 512 * 1024;
+
+// A real desktop-browser UA reduces the chance of an immediate Cloudflare
+// block on the unofficial Kick endpoint.
+constexpr char kBrowserUserAgent[] =
+    "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 "
+    "(KHTML, like Gecko) Chrome/152.0.0.0 Safari/537.36";
+
+net::NetworkTrafficAnnotationTag TrafficAnnotation() {
+  return net::DefineNetworkTrafficAnnotation("jah_golive_poller", R"(
+      semantics {
+        sender: "JahBrowser Go-Live Notifier"
+        description:
+          "Periodically fetches the public live status of the pinned Kick "
+          "channel (Jahrein) and a small curated follow list so JahBrowser "
+          "can show a system notification when any of them goes live, even "
+          "with no JahBrowser tab open."
+        trigger: "A 60-second background timer while the browser is running."
+        data:
+          "None. Only GETs to public channel endpoints; no user data, "
+          "credentials, or cookies are sent."
+        destination: OTHER
+        internal {
+          contacts {
+            email: "dev@jahbrowser.example"
+          }
+        }
+        user_data {
+          type: NONE
+        }
+        last_reviewed: "2026-07-05"
+      }
+      policy {
+        cookies_allowed: NO
+        setting: "This request cannot be disabled in this build."
+        policy_exception_justification:
+          "Not implemented; first-party go-live notification feature."
+      })");
+}
+
+// Returns nullopt on any parse failure (keep last state), otherwise the parsed
+// live status.
+struct LiveStatus {
+  bool is_live = false;
+  std::string title;
+};
+
+std::optional<LiveStatus> ParseKickResponse(
+    const std::optional<std::string>& body) {
+  if (!body) {
+    return std::nullopt;
+  }
+  std::optional<base::DictValue> root =
+      base::JSONReader::ReadDict(*body, base::JSON_PARSE_RFC);
+  if (!root) {
+    return std::nullopt;  // Almost certainly a Cloudflare HTML challenge page.
+  }
+  LiveStatus status;
+  const base::DictValue* ls = root->FindDict("livestream");
+  if (!ls) {
+    status.is_live = false;  // livestream == null -> offline.
+    return status;
+  }
+  status.is_live = ls->FindBool("is_live").value_or(true);
+  if (const std::string* t = ls->FindString("session_title")) {
+    status.title = *t;
+  }
+  return status;
+}
+
+}  // namespace
+
+JahGoLiveService::JahGoLiveService(Profile* profile) : profile_(profile) {
+  if (profile_) {
+    factory_ = profile_->GetDefaultStoragePartition()
+                   ->GetURLLoaderFactoryForBrowserProcess();
+  }
+  timer_.Start(FROM_HERE, kPollInterval,
+               base::BindRepeating(&JahGoLiveService::Poll,
+                                   base::Unretained(this)));
+  // Establish the baseline promptly so a transition can be detected soon.
+  Poll();
+}
+
+JahGoLiveService::~JahGoLiveService() = default;
+
+void JahGoLiveService::Shutdown() {
+  timer_.Stop();
+  loader_.reset();
+  weak_factory_.InvalidateWeakPtrs();
+}
+
+void JahGoLiveService::Poll() {
+  // Single-flight: skip if the previous sweep is still running.
+  if (fetch_in_progress_ || !factory_) {
+    return;
+  }
+  fetch_in_progress_ = true;
+  FetchChannel(0);
+}
+
+void JahGoLiveService::FetchChannel(size_t index) {
+  if (index >= kChannels.size()) {
+    fetch_in_progress_ = false;  // Sweep complete.
+    return;
+  }
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = GURL(base::StrCat(
+      {"https://kick.com/api/v2/channels/", kChannels[index].slug}));
+  request->method = "GET";
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+  request->headers.SetHeader(net::HttpRequestHeaders::kAccept,
+                             "application/json");
+  request->headers.SetHeader(net::HttpRequestHeaders::kUserAgent,
+                             kBrowserUserAgent);
+
+  loader_ =
+      network::SimpleURLLoader::Create(std::move(request), TrafficAnnotation());
+  loader_->SetTimeoutDuration(base::Seconds(15));
+  loader_->DownloadToString(
+      factory_.get(),
+      base::BindOnce(&JahGoLiveService::OnResponse,
+                     weak_factory_.GetWeakPtr(), index),
+      kMaxKickBytes);
+}
+
+void JahGoLiveService::OnResponse(size_t index,
+                                  std::optional<std::string> body) {
+  const bool net_ok = loader_ && loader_->NetError() == net::OK;
+  loader_.reset();
+
+  if (net_ok) {
+    if (std::optional<LiveStatus> status = ParseKickResponse(body)) {
+      const std::string slug = kChannels[index].slug;
+      auto it = was_live_.find(slug);
+      const bool had_baseline = it != was_live_.end();
+      const bool prev_live = had_baseline && it->second;
+      was_live_[slug] = status->is_live;
+
+      // Fire only on a real offline->live transition, never on the first poll.
+      if (had_baseline && !prev_live && status->is_live) {
+        ShowGoLiveNotification(slug, kChannels[index].display_name,
+                               status->title);
+      }
+    }
+    // On unparseable body (challenge page) we keep last state for this slug.
+  }
+  // On network error we keep last state; move on to the next channel either way.
+
+  FetchChannel(index + 1);
+}
+
+void JahGoLiveService::ShowGoLiveNotification(
+    const std::string& slug,
+    const std::string& display_name,
+    const std::string& stream_title) {
+  if (!profile_) {
+    return;
+  }
+  auto* display_service =
+      NotificationDisplayServiceFactory::GetForProfile(profile_);
+  if (!display_service) {
+    return;
+  }
+
+  std::u16string body = base::UTF8ToUTF16(stream_title);
+  if (body.empty()) {
+    body = u"Kick yayını şimdi canlı.";
+  }
+
+  const std::string notification_id = base::StrCat({"jah_golive_", slug});
+
+  auto delegate =
+      base::MakeRefCounted<message_center::HandleNotificationClickDelegate>(
+          base::BindRepeating(&JahGoLiveService::OpenChannel,
+                              weak_factory_.GetWeakPtr(), slug));
+
+  const GURL channel_url(base::StrCat({"https://kick.com/", slug}));
+  const std::u16string title =
+      base::StrCat({base::UTF8ToUTF16(display_name), u" yayın açtı!"});
+
+  message_center::Notification notification(
+      message_center::NOTIFICATION_TYPE_SIMPLE, notification_id, title, body,
+      ui::ImageModel(),
+      /*display_source=*/u"JahBrowser", channel_url,
+      message_center::NotifierId(message_center::NotifierType::SYSTEM_COMPONENT,
+                                 notification_id),
+      message_center::RichNotificationData(), std::move(delegate));
+
+  display_service->Display(NotificationHandler::Type::TRANSIENT, notification,
+                           /*metadata=*/nullptr);
+}
+
+void JahGoLiveService::OpenChannel(const std::string& slug) {
+  if (!profile_) {
+    return;
+  }
+  NavigateParams params(profile_, GURL(base::StrCat({"https://kick.com/", slug})),
+                        ui::PAGE_TRANSITION_LINK);
+  params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  Navigate(&params);
+}
