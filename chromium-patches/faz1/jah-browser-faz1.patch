diff --git a/chrome/browser/ui/webui/jah_home/jah_home_message_handler.cc b/chrome/browser/ui/webui/jah_home/jah_home_message_handler.cc
new file mode 100644
index 0000000000..f122763d8f
--- /dev/null
+++ b/chrome/browser/ui/webui/jah_home/jah_home_message_handler.cc
@@ -0,0 +1,178 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/jah_home/jah_home_message_handler.h"
+
+#include <string>
+#include <string_view>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "components/prefs/scoped_user_pref_update.h"
+#include "content/public/browser/web_ui.h"
+
+namespace {
+
+// Max accepted slug length; Kick/Twitch slugs are short.
+constexpr size_t kMaxSlugLength = 30;
+
+// The pinned hero channel is always shown separately and is never part of the
+// editable follow list.
+constexpr char kHeroSlug[] = "jahrein";
+
+// Default follow list seeded when the pref is empty/missing. Kick slugs are
+// lowercase; display is a nice-cased name.
+base::ListValue DefaultFollowList() {
+  base::ListValue list;
+  const struct {
+    const char* slug;
+    const char* display;
+  } kDefaults[] = {
+      {"swaggybark", "SwaggyBark"},
+      {"burhi", "Burhi"},
+      {"caglararts", "CaglarArts"},
+      {"buraksakinol", "BurakSakinol"},
+  };
+  for (const auto& d : kDefaults) {
+    base::DictValue dict;
+    dict.Set("slug", d.slug);
+    dict.Set("platform", "kick");
+    dict.Set("display", d.display);
+    list.Append(std::move(dict));
+  }
+  return list;
+}
+
+// Validates a slug: lowercase [a-z0-9_-], non-empty, <= kMaxSlugLength.
+bool IsValidSlug(std::string_view slug) {
+  if (slug.empty() || slug.size() > kMaxSlugLength) {
+    return false;
+  }
+  for (char c : slug) {
+    const bool ok = (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') ||
+                    c == '_' || c == '-';
+    if (!ok) {
+      return false;
+    }
+  }
+  return true;
+}
+
+// Returns the current follow list from prefs, falling back to the default seed
+// when the stored list is empty/missing.
+base::ListValue CurrentFollowList(PrefService* prefs) {
+  if (prefs) {
+    const base::ListValue& stored = prefs->GetList(prefs::kJahFollowChannels);
+    if (!stored.empty()) {
+      return stored.Clone();
+    }
+  }
+  return DefaultFollowList();
+}
+
+}  // namespace
+
+JahHomeMessageHandler::JahHomeMessageHandler() = default;
+JahHomeMessageHandler::~JahHomeMessageHandler() = default;
+
+void JahHomeMessageHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "jahGetFollows",
+      base::BindRepeating(&JahHomeMessageHandler::HandleGetFollows,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahAddFollow",
+      base::BindRepeating(&JahHomeMessageHandler::HandleAddFollow,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahRemoveFollow",
+      base::BindRepeating(&JahHomeMessageHandler::HandleRemoveFollow,
+                          base::Unretained(this)));
+}
+
+void JahHomeMessageHandler::HandleGetFollows(const base::ListValue& args) {
+  SendFollows();
+}
+
+void JahHomeMessageHandler::HandleAddFollow(const base::ListValue& args) {
+  Profile* profile = Profile::FromWebUI(web_ui());
+  if (!profile) {
+    SendFollows();
+    return;
+  }
+  // Args: [slug, platform, display].
+  const std::string* slug = args.size() > 0 ? args[0].GetIfString() : nullptr;
+  const std::string* platform =
+      args.size() > 1 ? args[1].GetIfString() : nullptr;
+  const std::string* display =
+      args.size() > 2 ? args[2].GetIfString() : nullptr;
+
+  if (!slug || !IsValidSlug(*slug) || *slug == kHeroSlug) {
+    SendFollows();
+    return;
+  }
+  const std::string resolved_platform =
+      (platform && *platform == "twitch") ? "twitch" : "kick";
+  const std::string resolved_display =
+      (display && !display->empty()) ? *display : *slug;
+
+  ScopedListPrefUpdate update(profile->GetPrefs(), prefs::kJahFollowChannels);
+  base::ListValue& list = update.Get();
+  // Seed the stored list with the default set on first edit so the user starts
+  // from the same 4 channels the fetcher shows.
+  if (list.empty()) {
+    list = DefaultFollowList();
+  }
+  // De-dupe by slug.
+  for (const base::Value& v : list) {
+    const base::DictValue* d = v.GetIfDict();
+    const std::string* s = d ? d->FindString("slug") : nullptr;
+    if (s && *s == *slug) {
+      SendFollows();
+      return;
+    }
+  }
+  base::DictValue dict;
+  dict.Set("slug", *slug);
+  dict.Set("platform", resolved_platform);
+  dict.Set("display", resolved_display);
+  list.Append(std::move(dict));
+
+  SendFollows();
+}
+
+void JahHomeMessageHandler::HandleRemoveFollow(const base::ListValue& args) {
+  Profile* profile = Profile::FromWebUI(web_ui());
+  const std::string* slug = args.size() > 0 ? args[0].GetIfString() : nullptr;
+  if (!profile || !slug) {
+    SendFollows();
+    return;
+  }
+  ScopedListPrefUpdate update(profile->GetPrefs(), prefs::kJahFollowChannels);
+  base::ListValue& list = update.Get();
+  // Seed before removing so removing from the implicit default set persists.
+  if (list.empty()) {
+    list = DefaultFollowList();
+  }
+  list.EraseIf([&slug](const base::Value& v) {
+    const base::DictValue* d = v.GetIfDict();
+    const std::string* s = d ? d->FindString("slug") : nullptr;
+    return s && *s == *slug;
+  });
+
+  SendFollows();
+}
+
+void JahHomeMessageHandler::SendFollows() {
+  AllowJavascript();
+  Profile* profile = Profile::FromWebUI(web_ui());
+  base::ListValue list =
+      CurrentFollowList(profile ? profile->GetPrefs() : nullptr);
+  web_ui()->CallJavascriptFunctionUnsafe("jahOnFollows",
+                                         base::Value(std::move(list)));
+}
