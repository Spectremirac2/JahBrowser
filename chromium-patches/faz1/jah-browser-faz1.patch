+R"JAHVOL(<!DOCTYPE html>
+<html lang="tr">
+<head>
+<meta charset="UTF-8">
+<title>Ses</title>
+<style>
+  :root{
+    --void:#0A0E13; --bg2:#0C1119; --panel:#0E141D; --elev:#141C28; --line:#1E2835;
+    --green:#33D14A; --cyan:#43B4CE; --cyan-deep:#2C7688; --text:#E4E8ED; --dim:#8A94A0; --muted:#59636F; --muted2:#3A434E;
+    --mono:ui-monospace,"Cascadia Mono","Consolas",monospace; --sans:"Segoe UI",system-ui,sans-serif; color-scheme:dark;
+  }
+  *{box-sizing:border-box;} html,body{margin:0;}
+  body{width:300px;background:var(--panel);color:var(--text);font-family:var(--sans);-webkit-font-smoothing:antialiased;user-select:none;}
+  .head{display:flex;align-items:center;gap:9px;padding:12px 14px;border-bottom:1px solid var(--line);}
+  .head .mk{width:20px;height:20px;color:var(--cyan);display:grid;place-items:center;}
+  .head .mk svg{width:18px;height:18px;}
+  .head b{font-size:13.5px;font-weight:700;flex:1;}
+  .head .site{font-family:var(--mono);font-size:11px;color:var(--cyan);}
+  .big{text-align:center;padding:18px 14px 4px;}
+  .big .pct{font-size:40px;font-weight:750;letter-spacing:-.02em;line-height:1;}
+  .big .pct em{color:var(--cyan);font-style:normal;}
+  .slider-wrap{padding:14px 16px 4px;}
+  input[type=range]{width:100%;-webkit-appearance:none;appearance:none;height:6px;border-radius:4px;background:var(--elev);outline:none;cursor:pointer;}
+  input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:#fff;box-shadow:0 0 8px rgba(67,180,206,.6);cursor:pointer;}
+  .slider-cap{display:flex;justify-content:space-between;padding:4px 16px 12px;font-family:var(--mono);font-size:10px;color:var(--muted);}
+  .presets{display:flex;gap:7px;padding:2px 14px 14px;}
+  .preset{flex:1;background:var(--bg2);border:1px solid var(--line);border-radius:8px;padding:8px 0;text-align:center;font-family:var(--mono);font-size:12px;color:var(--dim);cursor:pointer;}
+  .preset.active{border-color:var(--cyan);color:var(--cyan);background:rgba(67,180,206,.08);}
+  .preset:hover{color:var(--text);}
+  .mute-row{border-top:1px solid var(--line);padding:12px 14px;display:flex;align-items:center;gap:10px;color:var(--dim);font-size:13px;cursor:pointer;}
+  .mute-row svg{width:16px;height:16px;color:var(--muted);}
+  .mute-row.on{color:var(--cyan);} .mute-row.on svg{color:var(--cyan);}
+</style>
+</head>
+<body>
+  <div class="head">
+    <span class="mk"><svg viewBox="0 0 24 24"><path d="M4 9v6h4l5 4V5L8 9zM16 8a5 5 0 010 8M18.5 6a8 8 0 010 12" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" stroke-linecap="round"/></svg></span>
+    <b>Ses</b><span class="site">bu sekme</span>
+  </div>
+  <div class="big"><div class="pct"><em id="pctNum">100</em>%</div></div>
+  <div class="slider-wrap"><input type="range" id="vol" min="0" max="500" step="10" value="100"></div>
+  <div class="slider-cap"><span>%0</span><span>%100</span><span>%500</span></div>
+  <div class="presets">
+    <div class="preset" data-v="100">100%</div>
+    <div class="preset" data-v="200">200%</div>
+    <div class="preset" data-v="300">300%</div>
+    <div class="preset" data-v="500">500%</div>
+  </div>
+  <div class="mute-row" id="mute">
+    <svg viewBox="0 0 24 24"><path d="M4 9v6h4l5 4V5L8 9zM16 9l5 6M21 9l-5 6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" stroke-linecap="round"/></svg>
+    <span id="muteLbl">Sustur</span>
+  </div>
+
+<script>
+  var lastNonZero = 100;
+  function paint(v){
+    document.getElementById('pctNum').textContent = v;
+    document.getElementById('vol').value = v;
+    document.querySelectorAll('.preset').forEach(function(p){ p.classList.toggle('active', parseInt(p.dataset.v)===v); });
+    var m = document.getElementById('mute');
+    m.classList.toggle('on', v===0);
+    document.getElementById('muteLbl').textContent = v===0 ? 'Sesi aç' : 'Sustur';
+  }
+  function apply(v){
+    v = Math.max(0, Math.min(500, v));
+    if(v>0) lastNonZero = v;
+    paint(v);
+    chrome.send('jahSetVolume', [v]);
+  }
+  document.getElementById('vol').addEventListener('input', function(){ apply(parseInt(this.value)); });
+  document.querySelectorAll('.preset').forEach(function(p){ p.addEventListener('click', function(){ apply(parseInt(p.dataset.v)); }); });
+  document.getElementById('mute').addEventListener('click', function(){
+    var cur = parseInt(document.getElementById('vol').value);
+    apply(cur===0 ? lastNonZero : 0);
+  });
+  window.jahOnVolume = function(s){ if(s && typeof s.volume==='number') paint(s.volume); };
+  document.addEventListener('DOMContentLoaded', function(){ chrome.send('jahVolumeReady'); chrome.send('jahGetVolume'); });
+  chrome.send('jahVolumeReady'); chrome.send('jahGetVolume');
+</script>
+</body>
+</html>
+)JAHVOL"
