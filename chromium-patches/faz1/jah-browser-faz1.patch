+
+      var a = document.createElement("a");
+      var brand = brandFor(s.name);
+      a.className = "shortcut" + (brand ? " " + brand.cls : "");
+      a.href = safeUrl(s.url);
+      a.title = s.name;
+
+      var icon = document.createElement("span");
+      icon.className = "shortcut-icon";
+      icon.setAttribute("aria-hidden", "true");
+      if (brand) {
+        icon.innerHTML = brand.svg;
+      } else {
+        var fb = document.createElement("span");
+        fb.className = "shortcut-fallback-icon";
+        fb.textContent = s.name.charAt(0).toLocaleUpperCase("tr-TR");
+        icon.appendChild(fb);
+      }
+      var label = document.createElement("span");
+      label.className = "shortcut-label";
+      label.textContent = s.name;
+      a.appendChild(icon);
+      a.appendChild(label);
+
+      var rm = document.createElement("button");
+      rm.type = "button";
+      rm.className = "shortcut-remove";
+      rm.textContent = "×";
+      rm.title = T.removeTitle;
+      rm.setAttribute("aria-label", s.name + T.removeAria);
+      rm.addEventListener("click", function (e) {
+        e.preventDefault();
+        e.stopPropagation();
+        shortcuts.splice(i, 1);
+        saveShortcuts(shortcuts);
+        renderShortcuts();
+      });
+
+      wrap.appendChild(a);
+      wrap.appendChild(rm);
+      scGrid.appendChild(wrap);
+    });
+
+    var add = document.createElement("button");
+    add.type = "button";
+    add.className = "shortcut-add";
+    add.innerHTML = '<span class="plus" aria-hidden="true">+</span><span></span>';
+    add.lastChild.textContent = T.add;
+    add.addEventListener("click", function () {
+      var name = window.prompt(T.promptName);
+      if (name === null) return;
+      name = name.trim();
+      if (!name) return;
+      var url = window.prompt(T.promptUrl, "https://");
+      if (url === null) return;
+      shortcuts.push({ name: name.slice(0, 24), url: url.trim() });
+      saveShortcuts(shortcuts);
+      renderShortcuts();
+    });
+    scGrid.appendChild(add);
+  }
+
+  scEditBtn.addEventListener("click", function () {
+    scEditing = !scEditing;
+    scGrid.classList.toggle("is-editing", scEditing);
+    scEditBtn.textContent = scEditing ? T.editDone : T.edit;
+  });
+  renderShortcuts();
+
+  // ---------------- Kanal yoneticisi (chrome.send kontrati) ----------------
+  function jahSend(name, args) {
+    try {
+      if (window.chrome && typeof chrome.send === "function") {
+        chrome.send(name, args || []);
+        return true;
+      }
+    } catch (e) {}
+    return false;
+  }
+  function scheduleReload() {
+    // window.jahOnFollows paneli aninda yeniden cizer; canli takip satiri
+    // yeni listeyle (__JAH_FOLLOWS__) yeniden dolsun diye kisa sure sonra
+    // sayfayi tazeleriz.
+    setTimeout(function () { window.location.reload(); }, 500);
+  }
+
+  var scrim = document.getElementById("chanScrim");
+  var chanList = document.getElementById("chanList");
+  var chanAddForm = document.getElementById("chanAddForm");
+  var chanAddInput = document.getElementById("chanAddInput");
+
+  function openChanMgr() {
+    scrim.classList.add("is-open");
+    chanList.textContent = "";
+    var loadingEl = document.createElement("div");
+    loadingEl.className = "jah-chan-empty";
+    loadingEl.textContent = T.loading;
+    chanList.appendChild(loadingEl);
+    if (!jahSend("jahGetFollows")) {
+      loadingEl.textContent = T.loadErr;
+    }
+    setTimeout(function () { chanAddInput.focus(); }, 60);
+  }
+  function closeChanMgr() { scrim.classList.remove("is-open"); }
+
+  // Browser -> sayfa: takip listesini cizer.
+  window.jahOnFollows = function (list) {
+    chanList.textContent = "";
+    var arr = Array.isArray(list) ? list : [];
+    if (!arr.length) {
+      var empty = document.createElement("div");
+      empty.className = "jah-chan-empty";
+      empty.textContent = T.noFollows;
+      chanList.appendChild(empty);
+      return;
+    }
+    arr.forEach(function (ch) {
+      if (!ch || !ch.slug) return;
+      var row = document.createElement("div");
+      row.className = "jah-chan-row";
+
+      var info = document.createElement("div");
+      info.className = "jah-chan-info";
+      var nm = document.createElement("div");
+      nm.className = "jah-chan-name";
+      nm.textContent = ch.display || ch.slug;
+      var pl = document.createElement("div");
+      pl.className = "jah-chan-plat";
+      pl.textContent = (ch.platform || "kick") + " · " + ch.slug;
+      info.appendChild(nm);
+      info.appendChild(pl);
+
+      var rm = document.createElement("button");
+      rm.type = "button";
+      rm.className = "jah-chan-remove";
+      rm.textContent = T.chanRemove;
+      rm.addEventListener("click", function () {
+        if (jahSend("jahRemoveFollow", [ch.slug])) scheduleReload();
+      });
+
+      row.appendChild(info);
+      row.appendChild(rm);
+      chanList.appendChild(row);
+    });
+  };
+
+  document.getElementById("openChanMgr").addEventListener("click", openChanMgr);
+  document.getElementById("chanClose").addEventListener("click", closeChanMgr);
+  scrim.addEventListener("click", function (e) {
+    if (e.target === scrim) closeChanMgr();
+  });
+  document.addEventListener("keydown", function (e) {
+    if (e.key === "Escape" && scrim.classList.contains("is-open")) closeChanMgr();
+  });
+  chanAddForm.addEventListener("submit", function (e) {
+    e.preventDefault();
+    var slug = chanAddInput.value.trim().toLowerCase().replace(/^@/, "");
+    if (!slug) return;
+    if (jahSend("jahAddFollow", [slug, "kick", slug])) {
+      chanAddInput.value = "";
+      scheduleReload();
+    }
+  });
+})();
+</script>
+
+</body>
+</html>
+)JAHNTP"
