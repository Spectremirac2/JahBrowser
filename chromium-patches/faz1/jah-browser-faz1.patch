+// found in the LICENSE file.
+
+#ifndef COMPONENTS_JAH_BALTA_JAH_HOST_MATCHER_H_
+#define COMPONENTS_JAH_BALTA_JAH_HOST_MATCHER_H_
+
+#include <string_view>
+
+namespace jah_balta {
+
+// JahBrowser "Balta" host matcher. Returns true if a subresource request to
+// `host` should be blocked as an ad/tracker/analytics endpoint.
+//
+// Whitelist-first: if any registrable suffix of `host` is in the protected set
+// (Kick/Twitch, their stream/CDN infra, our emote infra) the request is NEVER
+// blocked. Otherwise it is blocked if any suffix is in the ad/tracker set.
+// Matching is case-insensitive.
+bool ShouldBlockHost(std::string_view host);
+
+}  // namespace jah_balta
+
+#endif  // COMPONENTS_JAH_BALTA_JAH_HOST_MATCHER_H_
