--- /dev/null
+++ b/chrome/browser/ui/webui/jah_volume/jah_volume_bubble_message_handler.cc
@@ -0,0 +1,99 @@
+// Copyright 2026 The JahBrowser Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/jah_volume/jah_volume_bubble_message_handler.h"
+
+#include <string>
+
+#include "base/functional/bind.h"
+#include "base/functional/callback_helpers.h"
+#include "base/strings/string_number_conversions.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/browser_window/public/profile_browser_collection.h"
+#include "chrome/browser/ui/webui/jah_volume/jah_volume_bubble_ui.h"
+#include "chrome/common/chrome_isolated_world_ids.h"
+#include "components/tabs/public/tab_interface.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+
+JahVolumeBubbleMessageHandler::JahVolumeBubbleMessageHandler() = default;
+JahVolumeBubbleMessageHandler::~JahVolumeBubbleMessageHandler() = default;
+
+void JahVolumeBubbleMessageHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "jahVolumeReady",
+      base::BindRepeating(&JahVolumeBubbleMessageHandler::HandleReady,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahGetVolume",
+      base::BindRepeating(&JahVolumeBubbleMessageHandler::HandleGet,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "jahSetVolume",
+      base::BindRepeating(&JahVolumeBubbleMessageHandler::HandleSetVolume,
+                          base::Unretained(this)));
+}
+
+void JahVolumeBubbleMessageHandler::HandleReady(const base::ListValue& args) {
+  auto* controller = static_cast<JahVolumeBubbleUI*>(web_ui()->GetController());
+  if (controller && controller->embedder()) {
+    controller->embedder()->ShowUI();
+  }
+}
+
+void JahVolumeBubbleMessageHandler::HandleGet(const base::ListValue& args) {
+  // Default to 100%; the slider drives changes live from here.
+  SendState(100);
+}
+
+content::WebContents* JahVolumeBubbleMessageHandler::ActiveTab() {
+  // Cycle-free browser access (avoids depending on the //chrome/browser/ui
+  // umbrella, which would create a toolbar<->webui dependency cycle).
+  Profile* profile = Profile::FromWebUI(web_ui());
+  if (!profile) {
+    return nullptr;
+  }
+  BrowserWindowInterface* browser =
+      ProfileBrowserCollection::GetForProfile(profile)->FindTabbedBrowser();
+  if (!browser) {
+    return nullptr;
+  }
+  tabs::TabInterface* tab = browser->GetActiveTabInterface();
+  return tab ? tab->GetContents() : nullptr;
+}
+
+void JahVolumeBubbleMessageHandler::HandleSetVolume(
+    const base::ListValue& args) {
+  if (args.empty()) {
+    return;
+  }
+  double pct = 100.0;
+  if (std::optional<double> d = args[0].GetIfDouble()) {
+    pct = *d;
+  } else if (std::optional<int> i = args[0].GetIfInt()) {
+    pct = *i;
+  } else {
+    return;
+  }
+  content::WebContents* wc = ActiveTab();
+  if (!wc) {
+    return;
+  }
+  const double gain = pct / 100.0;
+  const std::u16string js =
+      u"if(window.__jahSetVolume)window.__jahSetVolume(" +
+      base::NumberToString16(gain) + u")";
+  wc->GetPrimaryMainFrame()->ExecuteJavaScriptInIsolatedWorld(
+      js, base::NullCallback(), ISOLATED_WORLD_ID_JAH_MEDIA);
+}
+
+void JahVolumeBubbleMessageHandler::SendState(int volume_pct) {
+  AllowJavascript();
+  base::DictValue state;
+  state.Set("volume", volume_pct);
+  web_ui()->CallJavascriptFunctionUnsafe("jahOnVolume",
+                                         base::Value(std::move(state)));
+}
