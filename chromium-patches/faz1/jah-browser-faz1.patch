+#include "content/public/browser/web_ui_data_source.h"
+#include "net/base/net_errors.h"
+#include "net/base/url_util.h"
+#include "net/http/http_request_headers.h"
+#include "net/traffic_annotation/network_traffic_annotation.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "services/network/public/cpp/shared_url_loader_factory.h"
+#include "services/network/public/cpp/simple_url_loader.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
+#include "url/gurl.h"
+
+namespace {
+
+// The complete, self-contained Kick live side panel page (HTML + inline CSS +
+// inline JS). Placeholder tokens (__JAH_*__) are replaced by the browser
+// process with live Kick channel data before serving. Mirrors chrome://jah-home.
+constexpr char kJahLivePage[] =
+#include "chrome/browser/ui/webui/side_panel/jah_live/resources/jah_live_page.inc"
+    ;  // NOLINT(whitespace/semicolon)
+
+// A followed channel. "platform" is "kick" or "twitch" and selects the fetch
+// path (Kick public REST vs Twitch public web GraphQL). "slug" is the Kick
+// channel slug or the Twitch login (both lowercase).
+struct KickChannel {
+  const char* slug;
+  const char* display;
+  const char* platform;  // "kick" | "twitch"
+};
+
+// The pinned hero channel.
+constexpr KickChannel kHeroChannel = {"jahrein", "Jahrein", "kick"};
+
+// A resolved follow channel with owned strings (pref-derived or default seed).
+struct FollowChannel {
+  std::string slug;
+  std::string display;
+  std::string platform;  // "kick" | "twitch"
+};
+
+// Default follow list, used when the kJahFollowChannels pref is empty/missing.
+// Must stay in sync with browser_ui_prefs.cc and jah-home.
+std::vector<FollowChannel> DefaultFollowChannels() {
+  return {
+      {"swaggybark", "SwaggyBark", "kick"},
+      {"burhi", "Burhi", "kick"},
+      {"caglararts", "CaglarArts", "kick"},
+      {"buraksakinol", "BurakSakinol", "kick"},
+  };
+}
+
+// Reads the user-editable follow list from prefs into owned FollowChannel
+// structs, falling back to the default seed if empty/missing/malformed.
+std::vector<FollowChannel> ReadFollowChannels(PrefService* prefs) {
+  std::vector<FollowChannel> out;
+  if (prefs) {
+    const base::ListValue& list = prefs->GetList(prefs::kJahFollowChannels);
+    for (const base::Value& v : list) {
+      const base::DictValue* d = v.GetIfDict();
+      if (!d) {
+        continue;
+      }
+      const std::string* slug = d->FindString("slug");
+      if (!slug || slug->empty()) {
+        continue;
+      }
+      const std::string* platform = d->FindString("platform");
+      const std::string* display = d->FindString("display");
+      FollowChannel fc;
+      fc.slug = *slug;
+      fc.platform = (platform && *platform == "twitch") ? "twitch" : "kick";
+      fc.display = (display && !display->empty()) ? *display : *slug;
+      out.push_back(std::move(fc));
+    }
+  }
+  if (out.empty()) {
+    return DefaultFollowChannels();
+  }
+  return out;
+}
+
+std::string KickChannelUrl(std::string_view slug) {
+  return std::string("https://kick.com/api/v2/channels/").append(slug);
+}
+
+// Twitch's public web GraphQL endpoint and the well-known PUBLIC web client id
+// (kimne78kx3ncx6brgo4mv6wki5h1ko) that twitch.tv itself ships in its site JS.
+// No user credentials, OAuth token, or cookies are involved. A raw query for
+// public stream status works unauthenticated; if Twitch starts requiring an
+// integrity token, the fetch simply fails and the channel shows offline.
+constexpr char kTwitchGqlUrl[] = "https://gql.twitch.tv/gql";
+constexpr char kTwitchClientId[] = "kimne78kx3ncx6brgo4mv6wki5h1ko";
+
+// GQL body (JSON array, matching twitch.tv's batching format). "login" is a
+// trusted lowercase ASCII slug from kFollowChannels, so no escaping is needed.
+std::string TwitchGqlBody(std::string_view login) {
+  return std::string("[{\"query\":\"query{user(login:\\\"")
+      .append(login)
+      .append(
+          "\\\"){profileImageURL(width:70) stream{id viewersCount type "
+          "game{displayName}}}}\"}]");
+}
+
+constexpr size_t kMaxKickBytes = 512 * 1024;
+
+constexpr char kBrowserUserAgent[] =
+    "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 "
+    "(KHTML, like Gecko) Chrome/152.0.0.0 Safari/537.36";
+
+// Extracted live status for a Kick channel.
+struct JahLiveStatus {
+  bool ok = false;
+  bool is_live = false;
+  std::string title;
+  std::string category;
+  int viewers = 0;
+  int uptime_min = 0;
+  std::string avatar_url;  // root user.profile_pic (Kick CDN URL)
+};
+
+net::NetworkTrafficAnnotationTag KickTrafficAnnotation() {
+  return net::DefineNetworkTrafficAnnotation("jah_live_panel_kick_status", R"(
+      semantics {
+        sender: "JahBrowser Kick Live Side Panel"
+        description:
+          "Fetches the public live status (is-live, title, viewer count, "
+          "category) of the pinned Kick channel and the curated follow list "
+          "so the JahBrowser live side panel can show real live/offline rows."
+        trigger:
+          "Each load of the chrome://jah-live-side-panel.top-chrome side "
+          "panel."
+        data:
+          "None. Only GETs to public channel endpoints; no user data, "
+          "credentials, or cookies are sent."
+        destination: OTHER
+        internal {
+          contacts {
+            email: "dev@jahbrowser.example"
+          }
+        }
+        user_data {
+          type: NONE
+        }
+        last_reviewed: "2026-07-05"
+      }
+      policy {
+        cookies_allowed: NO
+        setting: "This request cannot be disabled; it powers the side panel."
+        policy_exception_justification:
+          "Not implemented; first-party side panel feature."
+      })");
+}
+
+std::string ToJsStringLiteral(std::string_view value) {
+  std::string out;
+  base::JSONWriter::Write(base::Value(std::string(value)), &out);
+  base::ReplaceSubstringsAfterOffset(&out, 0, "</", "<\\/");
+  return out;
+}
+
+// Wraps a Kick CDN avatar URL in a same-origin proxy URL the trusted WebUI page
+// can load via <img>. Empty in -> empty out (page keeps its letter fallback).
+std::string BuildAvatarProxyUrl(std::string_view avatar_url) {
+  if (avatar_url.empty()) {
+    return std::string();
+  }
+  return std::string("chrome://")
+      .append(chrome::kChromeUIJahLiveSidePanelHost)
+      .append("/jahavatar.png?u=")
+      .append(base::EscapeQueryParamValue(avatar_url, /*use_plus=*/false));
+}
+
+JahLiveStatus ParseKickResponse(const std::optional<std::string>& body) {
+  JahLiveStatus s;
+  if (!body) {
+    return s;
+  }
+  std::optional<base::DictValue> root =
+      base::JSONReader::ReadDict(*body, base::JSON_PARSE_RFC);
+  if (!root) {
+    return s;  // Almost certainly a Cloudflare HTML challenge page.
+  }
+  s.ok = true;
+
+  // Avatar lives at root user.profile_pic and exists whether live or offline.
+  if (const base::DictValue* user = root->FindDict("user")) {
+    if (const std::string* pic = user->FindString("profile_pic")) {
+      s.avatar_url = *pic;
+    }
+  }
+
+  const base::DictValue* ls = root->FindDict("livestream");
+  if (!ls) {
+    s.is_live = false;  // livestream == null -> offline.
+    return s;
+  }
+  s.is_live = ls->FindBool("is_live").value_or(true);
+  s.viewers = ls->FindInt("viewer_count").value_or(0);
+  if (const std::string* t = ls->FindString("session_title")) {
+    s.title = *t;
+  }
+  if (const base::ListValue* cats = ls->FindList("categories")) {
+    if (!cats->empty() && cats->front().is_dict()) {
+      if (const std::string* n = cats->front().GetDict().FindString("name")) {
+        s.category = *n;
+      }
+    }
+  }
+  if (const std::string* created = ls->FindString("created_at")) {
+    base::Time started;
+    if (base::Time::FromUTCString(created->c_str(), &started)) {
+      base::TimeDelta d = base::Time::Now() - started;
+      if (d.is_positive()) {
+        s.uptime_min = static_cast<int>(d.InMinutes());
+      }
+    }
+  }
+  return s;
+}
+
+net::NetworkTrafficAnnotationTag TwitchTrafficAnnotation() {
+  return net::DefineNetworkTrafficAnnotation("jah_live_panel_twitch_status", R"(
+      semantics {
+        sender: "JahBrowser Kick Live Side Panel"
+        description:
+          "Fetches the public live status (is-live, viewer count, category, "
+          "avatar) of curated Twitch channels via Twitch's public web GraphQL "
+          "endpoint so the JahBrowser live side panel can show real "
+          "live/offline rows for Twitch streamers."
+        trigger:
+          "Each load of the chrome://jah-live-side-panel.top-chrome side "
+          "panel."
+        data:
+          "A public GraphQL query containing only the channel login. No user "
+          "data, credentials, OAuth token, or cookies are sent; only the "
+          "public web Client-Id header twitch.tv itself ships is included."
+        destination: OTHER
+        internal {
+          contacts {
+            email: "dev@jahbrowser.example"
+          }
+        }
+        user_data {
+          type: NONE
+        }
+        last_reviewed: "2026-07-05"
+      }
+      policy {
+        cookies_allowed: NO
+        setting: "This request cannot be disabled; it powers the side panel."
+        policy_exception_justification:
+          "Not implemented; first-party side panel feature."
+      })");
+}
+
+// Parses Twitch's public GQL response: a JSON array whose first element is
+// {"data":{"user":{profileImageURL, stream:{viewersCount, game:{displayName}}}}}
+// stream == null (or user == null) means offline. Twitch's public query does
+// not expose the session title here, so title stays empty.
+JahLiveStatus ParseTwitchResponse(const std::optional<std::string>& body) {
+  JahLiveStatus s;
+  if (!body) {
+    return s;
+  }
+  std::optional<base::Value> root =
+      base::JSONReader::Read(*body, base::JSON_PARSE_RFC);
+  if (!root || !root->is_list() || root->GetList().empty() ||
+      !root->GetList().front().is_dict()) {
+    return s;
+  }
+  const base::DictValue* data =
+      root->GetList().front().GetDict().FindDict("data");
+  if (!data) {
+    return s;
+  }
+  s.ok = true;
+  const base::DictValue* user = data->FindDict("user");
+  if (!user) {
+    return s;  // Unknown login -> treated as offline.
+  }
+  if (const std::string* pic = user->FindString("profileImageURL")) {
+    s.avatar_url = *pic;
+  }
+  const base::DictValue* stream = user->FindDict("stream");
+  if (!stream) {
+    s.is_live = false;  // stream == null -> offline.
+    return s;
+  }
+  s.is_live = true;
+  s.viewers = stream->FindInt("viewersCount").value_or(0);
+  if (const base::DictValue* game = stream->FindDict("game")) {
+    if (const std::string* n = game->FindString("displayName")) {
+      s.category = *n;
+    }
+  }
+  return s;
+}
+
+// Serializes the follow-list statuses (aligned with `defs`) into a JSON array
+// the page consumes as __JAH_FOLLOWS__.
+std::string BuildFollowsJson(const std::vector<FollowChannel>& defs,
+                             const std::vector<JahLiveStatus>& follows) {
+  std::string out = "[";
+  for (size_t i = 0; i < defs.size(); ++i) {
+    const JahLiveStatus& s = i < follows.size() ? follows[i] : JahLiveStatus();
+    if (i) {
+      out += ",";
+    }
+    out += "{\"name\":" + ToJsStringLiteral(defs[i].display);
+    out += ",\"slug\":" + ToJsStringLiteral(defs[i].slug);
+    out += ",\"platform\":" + ToJsStringLiteral(defs[i].platform);
+    out += ",\"live\":";
+    out += s.is_live ? "true" : "false";
+    out += ",\"viewers\":" + base::NumberToString(s.viewers);
+    out += ",\"category\":" + ToJsStringLiteral(s.category);
+    out += ",\"avatar\":" +
+           ToJsStringLiteral(BuildAvatarProxyUrl(s.avatar_url));
+    out += ",\"uptime\":" + base::NumberToString(s.uptime_min);
+    out += ",\"ok\":";
+    out += s.ok ? "true" : "false";
+    out += "}";
+  }
+  out += "]";
+  return out;
+}
+
+std::string RenderJahLivePage(const JahLiveStatus& hero,
+                              const std::string& follows_json) {
+  std::string page(kJahLivePage);
+  const char* state =
+      !hero.ok ? "unknown" : (hero.is_live ? "live" : "offline");
+
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_OK__",
+                                         hero.ok ? "true" : "false");
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_LIVE_STATE__", state);
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_TITLE__",
+                                         ToJsStringLiteral(hero.title));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_VIEWERS__",
+                                         base::NumberToString(hero.viewers));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_CATEGORY__",
+                                         ToJsStringLiteral(hero.category));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_UPTIME__",
+                                         base::NumberToString(hero.uptime_min));
+  base::ReplaceFirstSubstringAfterOffset(
+      &page, 0, "__JAH_AVATAR__",
+      ToJsStringLiteral(BuildAvatarProxyUrl(hero.avatar_url)));
+  base::ReplaceFirstSubstringAfterOffset(&page, 0, "__JAH_FOLLOWS__",
+                                         follows_json);
+  return page;
+}
+
+// Self-owned: fetches the hero channel + the follow list concurrently in the
+// browser process (no CORS), then serves the page with live data injected.
+class JahLivePanelFetcher {
+ public:
+  static void Start(scoped_refptr<network::SharedURLLoaderFactory> factory,
+                    std::vector<FollowChannel> follows,
+                    content::WebUIDataSource::GotDataCallback callback) {
+    auto* self = new JahLivePanelFetcher(std::move(factory), std::move(follows),
+                                         std::move(callback));
+    self->FetchAll();
+  }
+
+ private:
+  JahLivePanelFetcher(scoped_refptr<network::SharedURLLoaderFactory> factory,
+                      std::vector<FollowChannel> follows,
+                      content::WebUIDataSource::GotDataCallback callback)
+      : factory_(std::move(factory)),
+        follows_def_(std::move(follows)),
+        callback_(std::move(callback)) {
+    total_ = 1 + follows_def_.size();
+    results_.resize(total_);
+    loaders_.resize(total_);
+    is_twitch_.assign(total_, false);
+  }
+
+  void FetchAll() {
+    if (!factory_) {
+      Finish();
+      return;
+    }
+    pending_ = total_;
+    StartOne(0, kHeroChannel.slug, kHeroChannel.platform);
+    for (size_t i = 0; i < follows_def_.size(); ++i) {
+      StartOne(i + 1, follows_def_[i].slug, follows_def_[i].platform);
+    }
+  }
+
+  void StartOne(size_t idx,
+                std::string_view slug,
+                std::string_view platform) {
+    const bool twitch = platform == "twitch";
+    is_twitch_[idx] = twitch;
+
+    auto request = std::make_unique<network::ResourceRequest>();
+    request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+    request->headers.SetHeader(net::HttpRequestHeaders::kUserAgent,
+                               kBrowserUserAgent);
+    if (twitch) {
+      // Public web GQL: POST with the well-known public Client-Id, no cookies.
+      request->url = GURL(kTwitchGqlUrl);
+      request->method = "POST";
+      request->headers.SetHeader("Client-Id", kTwitchClientId);
+    } else {
+      request->url = GURL(KickChannelUrl(slug));
+      request->method = "GET";
+      request->headers.SetHeader(net::HttpRequestHeaders::kAccept,
+                                 "application/json");
+    }
+
+    loaders_[idx] = network::SimpleURLLoader::Create(
+        std::move(request),
+        twitch ? TwitchTrafficAnnotation() : KickTrafficAnnotation());
+    loaders_[idx]->SetTimeoutDuration(base::Seconds(5));
+    if (twitch) {
+      loaders_[idx]->AttachStringForUpload(TwitchGqlBody(slug),
+                                           "application/json");
+    }
+    loaders_[idx]->DownloadToString(
+        factory_.get(),
+        base::BindOnce(&JahLivePanelFetcher::OnOne, base::Unretained(this),
+                       idx),
+        kMaxKickBytes);
+  }
+
+  void OnOne(size_t idx, std::optional<std::string> body) {
+    if (loaders_[idx]->NetError() == net::OK) {
+      results_[idx] = is_twitch_[idx] ? ParseTwitchResponse(body)
+                                      : ParseKickResponse(body);
+    }
+    if (--pending_ == 0) {
+      Finish();
+    }
+  }
+
+  void Finish() {
+    JahLiveStatus hero = results_.empty() ? JahLiveStatus() : results_[0];
+    std::vector<JahLiveStatus> follows;
+    for (size_t i = 1; i < results_.size(); ++i) {
+      follows.push_back(results_[i]);
+    }
+    std::move(callback_).Run(base::MakeRefCounted<base::RefCountedString>(
+        RenderJahLivePage(hero, BuildFollowsJson(follows_def_, follows))));
+    delete this;
+  }
+
+  scoped_refptr<network::SharedURLLoaderFactory> factory_;
+  std::vector<FollowChannel> follows_def_;
+  content::WebUIDataSource::GotDataCallback callback_;
+  std::vector<JahLiveStatus> results_;
+  std::vector<std::unique_ptr<network::SimpleURLLoader>> loaders_;
+  std::vector<bool> is_twitch_;
+  size_t total_ = 0;
+  size_t pending_ = 0;
+};
+
+// Cap proxied avatar bytes (~2 MB); avatars are tiny but be defensive.
+constexpr size_t kMaxAvatarBytes = 2 * 1024 * 1024;
+
+// 1x1 transparent PNG served for missing/rejected/failed avatars.
+constexpr uint8_t kTransparentPng[] = {
+    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A, 0x00, 0x00, 0x00, 0x0D,
+    0x49, 0x48, 0x44, 0x52, 0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
+    0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4, 0x89, 0x00, 0x00, 0x00,
+    0x0A, 0x49, 0x44, 0x41, 0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
+    0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00, 0x00, 0x00, 0x00, 0x49,
+    0x45, 0x4E, 0x44, 0xAE, 0x42, 0x60, 0x82};
+
+scoped_refptr<base::RefCountedMemory> TransparentPngBytes() {
+  return base::MakeRefCounted<base::RefCountedBytes>(
+      base::span<const uint8_t>(kTransparentPng));
+}
+
+// Only Kick's and Twitch's image CDNs may be proxied; every other host is
+// rejected. static-cdn.jtvnw.net serves Twitch profile images (jpg over https).
+bool IsKickAvatarUrl(const GURL& url) {
+  return url.is_valid() && url.SchemeIs("https") &&
+         (url.host() == "files.kick.com" || url.host() == "images.kick.com" ||
+          url.host() == "static-cdn.jtvnw.net");
+}
+
+// Self-owned single-shot loader: GETs one Kick avatar in the browser process
+// and serves the raw bytes back, or a transparent PNG on any failure.
+class JahAvatarProxy {
+ public:
+  static void Start(scoped_refptr<network::SharedURLLoaderFactory> factory,
+                    const GURL& image_url,
+                    content::WebUIDataSource::GotDataCallback callback) {
+    (new JahAvatarProxy(image_url, std::move(callback)))
+        ->Fetch(std::move(factory));
+  }
+
+ private:
+  JahAvatarProxy(const GURL& image_url,
+                 content::WebUIDataSource::GotDataCallback callback)
+      : image_url_(image_url), callback_(std::move(callback)) {}
+
+  void Fetch(scoped_refptr<network::SharedURLLoaderFactory> factory) {
+    if (!factory) {
+      Serve(TransparentPngBytes());
+      return;
+    }
+    auto request = std::make_unique<network::ResourceRequest>();
+    request->url = image_url_;
+    request->method = "GET";
+    request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+    request->headers.SetHeader(net::HttpRequestHeaders::kUserAgent,
+                               kBrowserUserAgent);
+    loader_ = network::SimpleURLLoader::Create(std::move(request),
+                                               KickTrafficAnnotation());
+    loader_->SetTimeoutDuration(base::Seconds(5));
+    loader_->DownloadToString(
+        factory.get(),
+        base::BindOnce(&JahAvatarProxy::OnLoaded, base::Unretained(this)),
+        kMaxAvatarBytes);
+  }
+
+  void OnLoaded(std::optional<std::string> body) {
+    if (loader_->NetError() == net::OK && body && !body->empty()) {
+      Serve(base::MakeRefCounted<base::RefCountedString>(std::move(*body)));
+    } else {
+      Serve(TransparentPngBytes());
+    }
+  }
+
+  void Serve(scoped_refptr<base::RefCountedMemory> bytes) {
+    std::move(callback_).Run(std::move(bytes));
+    delete this;
+  }
+
+  GURL image_url_;
+  content::WebUIDataSource::GotDataCallback callback_;
+  std::unique_ptr<network::SimpleURLLoader> loader_;
+};
+
+// Serve the single page for every request path (the page references no
+// external sub-resources).
+bool ShouldHandleJahLiveRequest(const std::string& path) {
+  return true;
+}
+
+void HandleJahLiveRequest(Profile* profile,
+                          const std::string& path,
+                          content::WebUIDataSource::GotDataCallback callback) {
+  scoped_refptr<network::SharedURLLoaderFactory> factory;
+  if (profile) {
+    factory = profile->GetDefaultStoragePartition()
+                  ->GetURLLoaderFactoryForBrowserProcess();
+  }
+
+  // Same-origin avatar proxy:
+  // chrome://jah-live-side-panel.top-chrome/jahavatar.png?u=<kick url>.
+  if (base::StartsWith(path, "jahavatar", base::CompareCase::SENSITIVE)) {
+    GURL request_url(std::string("chrome://")
+                         .append(chrome::kChromeUIJahLiveSidePanelHost)
+                         .append("/")
+                         .append(path));
+    std::string decoded;
+    GURL image_url;
+    if (net::GetValueForKeyInQuery(request_url, "u", &decoded)) {
+      image_url = GURL(decoded);
+    }
+    if (!IsKickAvatarUrl(image_url)) {
+      std::move(callback).Run(TransparentPngBytes());
+      return;
+    }
+    JahAvatarProxy::Start(std::move(factory), image_url, std::move(callback));
+    return;
+  }
+
+  // Resolve the user-editable follow list from the profile pref (or default).
+  PrefService* prefs = profile ? profile->GetPrefs() : nullptr;
+  JahLivePanelFetcher::Start(std::move(factory), ReadFollowChannels(prefs),
+                             std::move(callback));
+}
+
+}  // namespace
+
+JahLiveUI::JahLiveUI(content::WebUI* web_ui)
+    : TopChromeWebUIController(web_ui) {
+  Profile* const profile = Profile::FromWebUI(web_ui);
+  content::WebUIDataSource* source = content::WebUIDataSource::CreateAndAdd(
+      profile, chrome::kChromeUIJahLiveSidePanelHost);
+
+  source->SetRequestFilter(
+      base::BindRepeating(&ShouldHandleJahLiveRequest),
+      base::BindRepeating(&HandleJahLiveRequest, base::Unretained(profile)));
+
+  // The page uses inline <style>/<script> and assigns to Element.innerHTML.
+  // Relax the default Trusted-WebUI CSP accordingly for this first-party page.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  // Allow real Kick + Twitch avatar images (served from their CDNs) plus data:.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ImgSrc,
+      "img-src 'self' https://files.kick.com https://images.kick.com "
+      "https://static-cdn.jtvnw.net data:;");
+  source->DisableTrustedTypesCSP();
+}
+
+JahLiveUI::~JahLiveUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(JahLiveUI)
